{
  "$schema": "node_modules/wrangler/config-schema.json",
  // SOURCE config: @astrojs/cloudflare reads this at build for bindings/vars and
  // emits the deployable config at dist/server/wrangler.json (with the real
  // `main` and `assets.directory`). Deploy/dev therefore use the generated file:
  //   pnpm cf:deploy   (astro build && wrangler deploy -c dist/server/wrangler.json)
  //   pnpm cf:dev      (astro build && wrangler dev    -c dist/server/wrangler.json)
  "name": "murikah-web",
  // Dev-time entrypoint provided by @astrojs/cloudflare; the build replaces this.
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2025-05-21",
  // Node built-ins used by libSQL/other deps inside the Worker.
  "compatibility_flags": ["nodejs_compat"],

  // Static assets: serves the prerendered marketing pages from dist/.
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },

  "observability": {
    "enabled": true,
  },

  // KV, response cache, feature flags, and API rate-limit counters.
  // Create with: `wrangler kv namespace create CACHE` and paste the id below.
  // (Local `wrangler dev` simulates KV; a real id is only needed to deploy.)
  "kv_namespaces": [
    {
      "binding": "CACHE",
      "id": "REPLACE_WITH_KV_NAMESPACE_ID",
    },
  ],

  // R2, static asset overflow + the future downloadable Intelligence report.
  // Create with: `wrangler r2 bucket create murikah-assets`.
  "r2_buckets": [
    {
      "binding": "ASSETS_BUCKET",
      "bucket_name": "murikah-assets",
    },
  ],

  // The retention sweep runs from the companion Cron Worker (wrangler.cron.jsonc),
  // which calls the secured /api/cron/sweep endpoint on schedule. The Astro
  // adapter does not expose a `scheduled` export, so the trigger lives there.

  // Non-secret vars only. Secrets are referenced, never committed, set them with:
  //   wrangler secret put TURSO_DATABASE_URL
  //   wrangler secret put TURSO_AUTH_TOKEN
  //   wrangler secret put RESEND_API_KEY
  //   wrangler secret put CONTACT_NOTIFY_EMAIL
  //   wrangler secret put RESEND_FROM_EMAIL
  //   wrangler secret put ANTHROPIC_API_KEY   (only if using the AI assistant)
  //   wrangler secret put DEMO_HASH_SALT       (salt for hashing demo IPs)
  //   wrangler secret put CRON_SECRET          (shared with the Cron Worker)
  "vars": {
    "PUBLIC_SITE_URL": "https://www.murikah.com",
    // 'anthropic' (needs ANTHROPIC_API_KEY) or 'workers-ai' (needs an AI binding).
    "AI_PROVIDER": "anthropic",
  },
}
