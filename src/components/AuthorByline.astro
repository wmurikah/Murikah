---
/**
 * AuthorByline, the authorship signal on a guide. Murikah is a company, so
 * guides are attributed to the company, never to a named individual, and no
 * personal credentials appear here.
 */
import { SITE } from '@/site.config';

interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<div class:list={['flex items-center gap-3', className]}>
  {/* Aperture monogram: the brand mark, a ring of light around a Fraunces M. */}
  <span
    aria-hidden="true"
    class="grid size-10 shrink-0 place-items-center rounded-full bg-navy font-serif text-lg font-semibold text-gold ring-1 ring-gold/30"
  >
    M
  </span>
  <div>
    <p class="font-medium text-navy">{SITE.name}</p>
    <p class="text-sm text-slate">Independent assurance and AI governance</p>
  </div>
</div>
