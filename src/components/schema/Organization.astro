---
/**
 * Organization / ProfessionalService JSON-LD, emitted on every page (via
 * BaseLayout). Encodes the E-E-A-T trust foundation: the company, its founder
 * and credentials, the area served, and verified social profiles. Built from
 * site.config so nothing here goes beyond what the site states plainly.
 */
import { buildOrganization } from '@/lib/schema';

const schema = {
  '@context': 'https://schema.org',
  ...buildOrganization(),
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
