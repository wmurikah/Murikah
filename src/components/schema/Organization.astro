---
/**
 * Organization JSON-LD — emitted on every page (via BaseLayout). Encodes the
 * E-E-A-T trust foundation: the company, its founder and their credentials, the
 * area served, and verified contact + social profiles. No invented claims.
 */
import { SITE } from '@/site.config';
import { FOUNDER } from '@/site.config';
import { SOCIAL } from '@/site.config';

const orgId = `${SITE.url}/#organization`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': orgId,
  name: SITE.name,
  legalName: SITE.legalName,
  url: SITE.url,
  description: SITE.description,
  slogan: SITE.tagline,
  logo: new URL('/favicon.svg', SITE.url).href,
  foundingDate: String(SITE.foundingYear),
  areaServed: SITE.areaServed,
  email: SITE.email,
  sameAs: SOCIAL.map((s) => s.href),
  founder: {
    '@type': 'Person',
    name: FOUNDER.name,
    jobTitle: FOUNDER.role,
    // Credentials as E-E-A-T signals.
    hasCredential: FOUNDER.credentials.map((c) => ({
      '@type': 'EducationalOccupationalCredential',
      name: c,
    })),
  },
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
