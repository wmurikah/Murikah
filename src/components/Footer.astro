---
/**
 * Footer, a recurring "end" moment. A compact navy field: one brand block (mark
 * plus the wordmark, nothing stacked beneath), a single flat row of
 * navigation links with no column headers, a one-line newsletter capture, and a
 * thin bottom bar. Standards badges live on the About page, not here, and the
 * pronunciation cue sits on the home hero. `.on-dark` flips focus rings to gold.
 */
import Container from '@/components/primitives/Container.astro';
import Logo from '@/components/Logo.astro';
import SubscribeForm from '@/components/SubscribeForm.astro';
import { SITE, FOOTER_GROUPS, SOCIAL } from '@/site.config';

// Build-time year for the copyright line.
const year = new Date().getFullYear();

// One flat row of links, no headers. Legal moves to the bottom bar.
const navLinks = FOOTER_GROUPS.filter((g) => g.heading !== 'Legal').flatMap((g) => g.links);
const legalLinks = FOOTER_GROUPS.find((g) => g.heading === 'Legal')?.links ?? [];

const footLink = 'text-sm text-paper/70 no-underline transition-colors hover:text-white';
---

<footer class="navy-rich grain on-dark relative overflow-hidden text-paper">
  {/* The light signature: a fine gold beam across the top. */}
  <hr class="beam border-0" />

  <Container class="relative">
    <div class="flex flex-col gap-6 py-10">
      {/* Brand block plus the flat navigation row. */}
      <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
        <a href="/" class="inline-block no-underline" aria-label="Murikah, home">
          <Logo tone="light" />
        </a>
        <nav aria-label="Footer" class="flex flex-wrap gap-x-5 gap-y-2 lg:justify-end">
          {
            navLinks.map((l) => (
              <a href={l.href} class={footLink}>
                {l.label}
              </a>
            ))
          }
        </nav>
      </div>

      {/* Newsletter, a single compact row: short label, input, button. */}
      <div
        class="flex flex-col gap-3 border-t border-white/10 pt-6 sm:flex-row sm:items-center sm:justify-between"
      >
        <p class="text-sm text-paper/70">Occasional notes on assurance and governance. No noise.</p>
        <SubscribeForm
          source="newsletter"
          tone="dark"
          buttonLabel="Subscribe"
          successMessage="Thank you. We will send the occasional note, nothing more."
          class="w-full sm:w-auto sm:max-w-sm"
        />
      </div>

      {/* Bottom bar: copyright, legal and social, one thin row. */}
      <div
        class="flex flex-col gap-3 border-t border-white/10 pt-6 sm:flex-row sm:items-center sm:justify-between"
      >
        <p class="text-sm text-paper/55">© {year} {SITE.legalName}. All rights reserved.</p>
        <ul class="flex flex-wrap items-center gap-x-5 gap-y-2">
          {
            legalLinks.map((l) => (
              <li>
                <a href={l.href} class={footLink}>
                  {l.label}
                </a>
              </li>
            ))
          }
          {
            SOCIAL.map((s) => (
              <li>
                <a href={s.href} class={footLink} rel="me noopener" target="_blank">
                  {s.label}
                </a>
              </li>
            ))
          }
          <li>
            <a href={`mailto:${SITE.email}`} class={footLink}>{SITE.email}</a>
          </li>
        </ul>
      </div>
    </div>
  </Container>
</footer>
