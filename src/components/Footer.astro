---
/**
 * Footer, a recurring "end" moment (peak-end / serial-position). Compact
 * grouped sitemap (Miller's Law), the pronunciation cue, certification trust
 * signals (E-E-A-T), social + legal links and copyright. Navy field with
 * `.on-dark` so focus rings flip to gold.
 */
import Container from '@/components/primitives/Container.astro';
import Logo from '@/components/Logo.astro';
import SubscribeForm from '@/components/SubscribeForm.astro';
import { SITE, FOOTER_GROUPS, SOCIAL, FOUNDER } from '@/site.config';

// Build-time year for the copyright line.
const year = new Date().getFullYear();
---

<footer class="on-dark bg-navy text-paper">
  <Container>
    <div class="grid gap-10 py-14 md:grid-cols-12 lg:py-16">
      <div class="md:col-span-4">
        <a href="/" class="inline-block no-underline" aria-label="Murikah, home">
          <Logo tone="light" />
        </a>
        <p class="mt-4 max-w-xs text-sm text-paper/70">{SITE.tagline}</p>
        <p class="mt-2 text-sm text-paper/60">Pronounced {SITE.pronunciation}.</p>

        {/* Certification trust signals. */}
        <ul class="mt-5 flex flex-wrap gap-2" aria-label="Certifications and credentials">
          {
            FOUNDER.credentials.map((c) => (
              <li class="rounded-full bg-white/10 px-2.5 py-1 text-xs text-paper/85">{c}</li>
            ))
          }
        </ul>
      </div>

      <nav aria-label="Footer" class="grid grid-cols-2 gap-8 sm:grid-cols-3 md:col-span-8 md:pl-8">
        {
          FOOTER_GROUPS.map((group) => (
            <div>
              <h2 class="text-sm font-semibold tracking-wide text-white uppercase">
                {group.heading}
              </h2>
              <ul class="mt-3 space-y-2.5">
                {group.links.map((l) => (
                  <li>
                    <a
                      href={l.href}
                      class="text-sm text-paper/75 no-underline hover:text-white hover:underline"
                    >
                      {l.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </nav>
    </div>

    {/* Newsletter, a quiet single-field capture posting to /api/subscribe. */}
    <div class="border-t border-white/10 py-10">
      <div class="grid gap-6 md:grid-cols-2 md:items-center">
        <div>
          <p class="font-medium text-white">Notes worth reading</p>
          <p class="mt-1 max-w-md text-sm text-paper/70">
            Occasional notes on assurance, AI governance and audit software. No noise.
          </p>
        </div>
        <SubscribeForm
          source="newsletter"
          tone="dark"
          buttonLabel="Subscribe"
          successMessage="Thank you. We will send the occasional note, nothing more."
          class="md:w-full md:max-w-sm md:justify-self-end"
        />
      </div>
    </div>

    <div
      class="flex flex-col gap-4 border-t border-white/10 py-6 sm:flex-row sm:items-center sm:justify-between"
    >
      <p class="text-sm text-paper/60">
        © {year}
        {SITE.legalName}. All rights reserved.
      </p>
      <ul class="flex flex-wrap items-center gap-x-5 gap-y-2">
        {
          SOCIAL.map((s) => (
            <li>
              <a
                href={s.href}
                class="text-sm text-paper/75 no-underline hover:text-white"
                rel="me noopener"
                target="_blank"
              >
                {s.label}
              </a>
            </li>
          ))
        }
        <li>
          <a
            href={`mailto:${SITE.email}`}
            class="text-sm text-paper/75 no-underline hover:text-white">{SITE.email}</a
          >
        </li>
      </ul>
    </div>
  </Container>
</footer>
