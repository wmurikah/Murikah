---
/**
 * Header, site chrome following familiar conventions (Jakob's Law): logo
 * top-left links home, three primary nav groups, the single gold CTA furthest
 * right. The nav is deliberately small (Hick's Law: Who we are, What we do,
 * News & Insights + one action). All three groups come straight from `NAV` in
 * site.config, so order and contents stay single-source.
 *
 * Desktop: each group's trigger is a real link to its hub that also reveals a
 * disclosure menu of the group's pages on hover and keyboard focus
 * (group-hover / group-focus-within, no JavaScript). Mobile: a keyboard-operable
 * menu with focus trapping and body-scroll lock, where each group is an
 * expandable <details> section. Progressive enhancement, every link works
 * without JS.
 */
import Container from '@/components/primitives/Container.astro';
import Button from '@/components/primitives/Button.astro';
import Logo from '@/components/Logo.astro';
import { NAV, PRIMARY_CTA } from '@/site.config';
import type { NavItem } from '@/site.config';

const path = Astro.url.pathname;

// A group is active on any of its owned route prefixes (its `match` list, or
// its own href by default). Hash-only child links share the group's hub route.
const groupActive = (item: NavItem) =>
  (item.match ?? [item.href]).some((p) => path === p || path.startsWith(p + '/'));

// Inline editorial links on a dark header: no pill, no boxed tabs. A fine brass
// underline grows in on hover, on keyboard focus, while the group's menu is
// open, and stays lit on the active group (aria-current="page"). Links sit in
// ivory and brighten to white, so the header reads as open, dark and premium.
const navLink =
  'relative inline-flex min-h-[2.75rem] items-center gap-1 px-0.5 text-sm font-medium text-paper/75 transition-colors duration-150 hover:text-white focus-visible:text-white aria-[current=page]:text-white ' +
  'after:pointer-events-none after:absolute after:inset-x-0 after:bottom-[0.7rem] after:h-px after:origin-left after:scale-x-0 after:bg-brass after:transition-transform after:duration-200 ' +
  'hover:after:scale-x-100 focus-visible:after:scale-x-100 group-hover:after:scale-x-100 group-focus-within:after:scale-x-100 aria-[current=page]:after:scale-x-100';
---

<header
  class="on-dark sticky top-0 z-50 border-b border-white/10 bg-obsidian/85 shadow-[0_1px_30px_rgba(0,0,0,0.4)] backdrop-blur-xl"
>
  <Container>
    <div class="flex h-16 items-center justify-between lg:h-[4.5rem]">
      {/* Logo, top-left, links home (Jakob's Law). */}
      <a href="/" class="rounded-md no-underline" aria-label="Murikah, home">
        <Logo tone="light" />
      </a>

      {
        /* Desktop primary nav, three groups mapped straight from NAV. Inline
          text links, no enclosing pill, with calm spacing between groups. */
      }
      <nav aria-label="Primary" class="hidden items-center gap-8 lg:flex">
        {
          NAV.map((item) =>
            item.children ? (
              <div class="group relative">
                {/* The trigger is a real link to the hub, so it works on click,
                    on touch and for keyboard users; the menu reveals on hover
                    and focus-within with no JavaScript. */}
                <a
                  href={item.href}
                  class={navLink}
                  aria-current={groupActive(item) ? 'page' : undefined}
                >
                  {item.label}
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 16 16"
                    fill="none"
                    aria-hidden="true"
                    class="transition-transform duration-200 group-focus-within:rotate-180 group-hover:rotate-180"
                  >
                    <path
                      d="M4 6l4 4 4-4"
                      stroke="currentColor"
                      stroke-width="1.75"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </a>

                {/* Disclosure menu. The pt-3 wrapper is a transparent hover
                    bridge so the pointer never crosses a dead gap. */}
                <div class="invisible absolute top-full left-1/2 z-50 w-[26rem] -translate-x-1/2 pt-3 opacity-0 transition-opacity duration-150 group-focus-within:visible group-focus-within:opacity-100 group-hover:visible group-hover:opacity-100">
                  <div class="rounded-[1.4rem] bg-obsidian/95 p-2 shadow-pop ring-1 ring-white/10 backdrop-blur-xl">
                    <ul class="grid gap-0.5">
                      {item.children.map((c) => (
                        <li>
                          <a
                            href={c.href}
                            class="group/row flex items-start gap-3 rounded-xl px-3 py-2.5 no-underline transition-colors hover:bg-white/5"
                          >
                            <span class="mt-1.5 size-1.5 shrink-0 rounded-full bg-brass transition-transform group-hover/row:scale-125" />
                            <span>
                              <span class="block text-sm font-medium text-white">{c.label}</span>
                              <span class="mt-0.5 block text-xs leading-snug text-paper/55">
                                {c.description}
                              </span>
                            </span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            ) : (
              <a
                href={item.href}
                class={navLink}
                aria-current={groupActive(item) ? 'page' : undefined}
              >
                {item.label}
              </a>
            ),
          )
        }
      </nav>

      {/* Desktop CTA, the single gold action (Von Restorff). */}
      <div class="hidden lg:block">
        <Button href={PRIMARY_CTA.href} variant="primary">{PRIMARY_CTA.label}</Button>
      </div>

      {/* Mobile menu toggle, 44px tap target (Fitts's Law). */}
      <button
        type="button"
        class="inline-flex size-11 items-center justify-center rounded-md text-paper hover:bg-white/10 lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
        data-mobile-toggle
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M4 7h16M4 12h16M4 17h16"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"></path>
        </svg>
      </button>
    </div>
  </Container>

  {/* Mobile menu panel */}
  <div
    id="mobile-menu"
    data-mobile-panel
    hidden
    class="on-dark border-t border-white/10 bg-obsidian lg:hidden"
  >
    <Container>
      <nav aria-label="Mobile" class="flex flex-col gap-1 py-4">
        {
          NAV.map((item) =>
            item.children ? (
              <details class="group/m rounded-lg">
                <summary
                  class:list={[
                    'flex min-h-[2.75rem] cursor-pointer list-none items-center justify-between rounded-lg px-3 py-3 font-medium text-paper hover:bg-white/5 [&::-webkit-details-marker]:hidden',
                    groupActive(item) && 'bg-white/5',
                  ]}
                  aria-current={groupActive(item) ? 'page' : undefined}
                >
                  {item.label}
                  <svg
                    width="18"
                    height="18"
                    viewBox="0 0 16 16"
                    fill="none"
                    aria-hidden="true"
                    class="text-paper/60 transition-transform duration-200 group-open/m:rotate-180"
                  >
                    <path
                      d="M4 6l4 4 4-4"
                      stroke="currentColor"
                      stroke-width="1.75"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </summary>
                <div class="mt-1 mb-1 flex flex-col gap-0.5 border-l border-white/10 pl-3">
                  {item.children.map((c) => (
                    <a
                      href={c.href}
                      class="rounded-lg px-3 py-2.5 text-paper/80 no-underline hover:bg-white/5 hover:text-white"
                    >
                      {c.label}
                    </a>
                  ))}
                </div>
              </details>
            ) : (
              <a
                href={item.href}
                class:list={[
                  'rounded-lg px-3 py-3 font-medium text-paper no-underline hover:bg-white/5',
                  groupActive(item) && 'bg-white/5',
                ]}
                aria-current={groupActive(item) ? 'page' : undefined}
              >
                {item.label}
              </a>
            ),
          )
        }
        <div class="px-1 pt-3">
          <Button href={PRIMARY_CTA.href} variant="primary" class="w-full">
            {PRIMARY_CTA.label}
          </Button>
        </div>
      </nav>
    </Container>
  </div>
</header>

<script>
  // Mobile menu only. The desktop disclosures are pure CSS (group-hover /
  // group-focus-within), so there is no dropdown JavaScript to fail.
  // Progressive enhancement: every link works without this script.
  function initNav() {
    const mToggle = document.querySelector<HTMLElement>('[data-mobile-toggle]');
    const mPanel = document.querySelector<HTMLElement>('[data-mobile-panel]');
    if (mToggle && mPanel) {
      const focusables = () =>
        Array.from(
          mPanel.querySelectorAll<HTMLElement>('a[href], button:not([disabled]), summary'),
        );

      const setOpen = (open: boolean) => {
        mToggle.setAttribute('aria-expanded', String(open));
        mToggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
        mPanel.hidden = !open;
        document.body.classList.toggle('overflow-hidden', open);
        if (open) focusables()[0]?.focus();
      };

      mToggle.addEventListener('click', () => {
        setOpen(mToggle.getAttribute('aria-expanded') !== 'true');
      });
      // Close when a destination link is tapped, but not when toggling a
      // group's <summary> disclosure.
      mPanel.addEventListener('click', (e: MouseEvent) => {
        const el = e.target as HTMLElement;
        if (el.closest('a') && !el.closest('summary')) setOpen(false);
      });
      document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape' && mToggle.getAttribute('aria-expanded') === 'true') {
          setOpen(false);
          mToggle.focus();
        }
      });
      // Trap focus within the open mobile menu.
      mPanel.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key !== 'Tab') return;
        const f = focusables();
        if (f.length === 0) return;
        const first = f[0];
        const last = f[f.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      });
    }
  }

  initNav();
</script>
