---
/**
 * Header, site chrome following familiar conventions (Jakob's Law): logo
 * top-left links home, primary nav top-right, the single gold CTA furthest
 * right. The nav is deliberately small (Hick's Law: Home, About, Services,
 * Assurance OS, Pricing + one action). Items are ordered by importance
 * (serial-position effect) and come straight from `NAV` in site.config.
 *
 * Desktop: the Services item is a link to the /services hub that also reveals a
 * disclosure menu of the five service lines on hover and keyboard focus
 * (group-hover / group-focus-within, no JavaScript). Mobile: a keyboard-operable
 * menu with focus trapping and body-scroll lock, where Services is an
 * expandable <details> section. Progressive enhancement, every link works
 * without JS.
 */
import Container from '@/components/primitives/Container.astro';
import Button from '@/components/primitives/Button.astro';
import Logo from '@/components/Logo.astro';
import { NAV, PRIMARY_CTA } from '@/site.config';

const path = Astro.url.pathname;

const isActive = (href: string) =>
  path === href || (href !== '/' && path.startsWith(href + '/')) || path === href + '/';

// The Services trigger is "active" on the hub and on any of its five child
// lines (Assurance OS is a separate top-level item, so it is not counted here).
const servicesItem = NAV.find((n) => n.children);
const serviceGroupHrefs = ['/services', ...(servicesItem?.children?.map((c) => c.href) ?? [])];
const servicesActive = serviceGroupHrefs.some((h) => path === h || path.startsWith(h + '/'));

const navLink =
  'inline-flex min-h-[2.75rem] items-center gap-1 rounded-full px-4 text-sm font-medium text-ink/80 transition-colors duration-150 hover:bg-white hover:text-navy';
const activeLink = 'bg-white text-navy shadow-card';
---

<header
  class="sticky top-0 z-50 border-b border-white/60 bg-white/72 shadow-[0_1px_30px_rgba(11,23,51,0.06)] backdrop-blur-xl"
>
  <Container>
    <div class="flex h-16 items-center justify-between lg:h-[4.5rem]">
      {/* Logo, top-left, links home (Jakob's Law). */}
      <a href="/" class="rounded-md no-underline" aria-label="Murikah, home">
        <Logo />
      </a>

      {/* Desktop primary nav, mapped straight from NAV so order stays single-source. */}
      <nav
        aria-label="Primary"
        class="hidden items-center gap-1 rounded-full bg-paper/70 p-1 ring-1 ring-hairline/70 lg:flex"
      >
        {
          NAV.map((item) =>
            item.children ? (
              <div class="group relative">
                {/* The trigger is a real link to the hub, so it works on click,
                    on touch and for keyboard users; the menu reveals on hover
                    and focus-within with no JavaScript. */}
                <a
                  href={item.href}
                  class:list={[navLink, servicesActive && activeLink]}
                  aria-current={servicesActive ? 'page' : undefined}
                >
                  {item.label}
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 16 16"
                    fill="none"
                    aria-hidden="true"
                    class="transition-transform duration-200 group-focus-within:rotate-180 group-hover:rotate-180"
                  >
                    <path
                      d="M4 6l4 4 4-4"
                      stroke="currentColor"
                      stroke-width="1.75"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </a>

                {/* Disclosure menu. The pt-3 wrapper is a transparent hover
                    bridge so the pointer never crosses a dead gap. */}
                <div class="invisible absolute top-full right-0 z-50 w-[24rem] pt-3 opacity-0 transition-opacity duration-150 group-focus-within:visible group-focus-within:opacity-100 group-hover:visible group-hover:opacity-100">
                  <div class="rounded-[1.4rem] bg-white/95 p-2 shadow-pop ring-1 ring-hairline backdrop-blur-xl">
                    <div class="flex items-center justify-between gap-4 border-b border-hairline px-2 pb-2">
                      <p class="text-xs font-medium tracking-[0.08em] text-slate uppercase">
                        Choose a service
                      </p>
                      <a
                        href={item.href}
                        class="text-xs font-medium text-blue no-underline hover:underline"
                      >
                        View all
                      </a>
                    </div>
                    <ul class="mt-2 grid grid-cols-2 gap-1">
                      {item.children.map((c) => (
                        <li>
                          <a
                            href={c.href}
                            class="group/row flex items-center gap-3 rounded-xl px-3 py-2.5 no-underline transition-colors hover:bg-paper"
                          >
                            <span class="size-2 rounded-full bg-gold transition-transform group-hover/row:scale-125" />
                            <span>
                              <span class="block text-sm font-medium text-navy">{c.label}</span>
                              <span class="mt-0.5 block text-xs text-slate">{c.description}</span>
                            </span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            ) : (
              <a
                href={item.href}
                class:list={[navLink, isActive(item.href) && activeLink]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            ),
          )
        }
      </nav>

      {/* Desktop CTA, the single gold action (Von Restorff). */}
      <div class="hidden lg:block">
        <Button href={PRIMARY_CTA.href} variant="primary">{PRIMARY_CTA.label}</Button>
      </div>

      {/* Mobile menu toggle, 44px tap target (Fitts's Law). */}
      <button
        type="button"
        class="inline-flex size-11 items-center justify-center rounded-md text-navy hover:bg-paper-shade lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
        data-mobile-toggle
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M4 7h16M4 12h16M4 17h16"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"></path>
        </svg>
      </button>
    </div>
  </Container>

  {/* Mobile menu panel */}
  <div
    id="mobile-menu"
    data-mobile-panel
    hidden
    class="border-t border-hairline bg-paper lg:hidden"
  >
    <Container>
      <nav aria-label="Mobile" class="flex flex-col gap-1 py-4">
        {
          NAV.map((item) =>
            item.children ? (
              <details class="group/m rounded-lg">
                <summary class="flex min-h-[2.75rem] cursor-pointer list-none items-center justify-between rounded-lg px-3 py-3 font-medium text-navy hover:bg-paper-shade [&::-webkit-details-marker]:hidden">
                  {item.label}
                  <svg
                    width="18"
                    height="18"
                    viewBox="0 0 16 16"
                    fill="none"
                    aria-hidden="true"
                    class="text-slate transition-transform duration-200 group-open/m:rotate-180"
                  >
                    <path
                      d="M4 6l4 4 4-4"
                      stroke="currentColor"
                      stroke-width="1.75"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </summary>
                <div class="mt-1 mb-1 flex flex-col gap-0.5 border-l border-hairline pl-3">
                  <a
                    href={item.href}
                    class="rounded-lg px-3 py-2.5 text-sm font-medium text-blue no-underline hover:bg-paper-shade"
                  >
                    Services overview
                  </a>
                  {item.children.map((c) => (
                    <a
                      href={c.href}
                      class="rounded-lg px-3 py-2.5 text-navy no-underline hover:bg-paper-shade"
                    >
                      {c.label}
                    </a>
                  ))}
                </div>
              </details>
            ) : (
              <a
                href={item.href}
                class:list={[
                  'rounded-lg px-3 py-3 font-medium text-navy no-underline hover:bg-paper-shade',
                  isActive(item.href) && 'bg-paper-shade',
                ]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            ),
          )
        }
        <div class="px-1 pt-3">
          <Button href={PRIMARY_CTA.href} variant="primary" class="w-full">
            {PRIMARY_CTA.label}
          </Button>
        </div>
      </nav>
    </Container>
  </div>
</header>

<script>
  // Mobile menu only. The desktop Services disclosure is pure CSS
  // (group-hover / group-focus-within), so there is no dropdown JavaScript to
  // fail. Progressive enhancement: every link works without this script.
  function initNav() {
    const mToggle = document.querySelector<HTMLElement>('[data-mobile-toggle]');
    const mPanel = document.querySelector<HTMLElement>('[data-mobile-panel]');
    if (mToggle && mPanel) {
      const focusables = () =>
        Array.from(
          mPanel.querySelectorAll<HTMLElement>('a[href], button:not([disabled]), summary'),
        );

      const setOpen = (open: boolean) => {
        mToggle.setAttribute('aria-expanded', String(open));
        mToggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
        mPanel.hidden = !open;
        document.body.classList.toggle('overflow-hidden', open);
        if (open) focusables()[0]?.focus();
      };

      mToggle.addEventListener('click', () => {
        setOpen(mToggle.getAttribute('aria-expanded') !== 'true');
      });
      // Close when a destination link is tapped, but not when toggling the
      // Services <summary> disclosure.
      mPanel.addEventListener('click', (e: MouseEvent) => {
        const el = e.target as HTMLElement;
        if (el.closest('a') && !el.closest('summary')) setOpen(false);
      });
      document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape' && mToggle.getAttribute('aria-expanded') === 'true') {
          setOpen(false);
          mToggle.focus();
        }
      });
      // Trap focus within the open mobile menu.
      mPanel.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key !== 'Tab') return;
        const f = focusables();
        if (f.length === 0) return;
        const first = f[0];
        const last = f[f.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      });
    }
  }

  initNav();
</script>
