---
/** FeatureGrid — responsive equal-gap grid for grouped items (Miller / Gestalt). */
interface Props {
  cols?: 2 | 3 | 4;
  class?: string;
}
const { cols = 3, class: className } = Astro.props;

const colClass: Record<number, string> = {
  2: 'sm:grid-cols-2',
  3: 'sm:grid-cols-2 lg:grid-cols-3',
  4: 'sm:grid-cols-2 lg:grid-cols-4',
};
---

<div class:list={['grid grid-cols-1 gap-5 sm:gap-6', colClass[cols], className]}>
  <slot />
</div>
