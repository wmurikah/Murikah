---
/**
 * Prose, long-form/MDX wrapper applying the type system: a constrained measure
 * (68ch, about 60 to 75 characters), comfortable rhythm, and styled headings, links,
 * quotes, code and tables. Hand-written (no typography plugin) to keep deps and
 * shipped CSS minimal. Styles are `is:global` so they reach slotted MDX nodes.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<div class:list={['prose-murikah', className]}>
  <slot />
</div>

<style is:global>
  .prose-murikah {
    max-width: 68ch;
    color: var(--color-ink);
    font-size: 1.1875rem;
    line-height: 1.75;
  }
  .prose-murikah > * + * {
    margin-top: 1.2em;
  }
  /* The opening paragraph reads as a lead. */
  .prose-murikah > p:first-of-type {
    font-size: 1.3125rem;
    line-height: 1.6;
    color: var(--color-ink);
  }
  /* Headings in Fraunces so the reading experience carries the brand voice. */
  .prose-murikah h2 {
    margin-top: 2em;
    margin-bottom: 0.45em;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: var(--text-3xl);
    line-height: 1.12;
    letter-spacing: -0.015em;
    color: var(--color-navy);
    scroll-margin-top: 6rem;
  }
  .prose-murikah h3 {
    margin-top: 1.7em;
    margin-bottom: 0.3em;
    font-weight: 600;
    font-size: var(--text-xl);
    line-height: 1.3;
    color: var(--color-navy);
    scroll-margin-top: 6rem;
  }
  .prose-murikah a {
    color: var(--color-blue);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }
  .prose-murikah a:hover {
    color: var(--color-blue-deep);
  }
  .prose-murikah strong {
    color: var(--color-navy);
    font-weight: 600;
  }
  .prose-murikah ul,
  .prose-murikah ol {
    padding-left: 1.4em;
  }
  .prose-murikah ul {
    list-style: disc;
  }
  .prose-murikah ol {
    list-style: decimal;
  }
  .prose-murikah li + li {
    margin-top: 0.4em;
  }
  /* Pull quote: Fraunces italic, set larger and quieter, with a short gold beam
     instead of a heavy rule. A calm editorial pause. */
  .prose-murikah blockquote {
    margin-top: 1.8em;
    margin-bottom: 1.8em;
    padding-top: 0.2em;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.5rem;
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: var(--color-navy);
  }
  .prose-murikah blockquote::before {
    content: '';
    display: block;
    inline-size: 2.5rem;
    block-size: 2px;
    margin-bottom: 0.7em;
    background: linear-gradient(90deg, var(--color-gold), transparent);
  }
  .prose-murikah blockquote p {
    margin: 0;
  }
  .prose-murikah code {
    font-family: ui-monospace, 'SF Mono', 'Cascadia Code', monospace;
    font-size: 0.9em;
    background: var(--color-paper-shade);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }
  .prose-murikah pre {
    background: var(--color-navy-deep);
    color: #e9edf5;
    padding: 1.1em 1.25em;
    border-radius: var(--radius-card);
    overflow-x: auto;
  }
  .prose-murikah pre code {
    background: none;
    padding: 0;
    color: inherit;
  }
  .prose-murikah img {
    border-radius: var(--radius-card);
  }
  .prose-murikah hr {
    border: 0;
    border-top: 1px solid var(--color-hairline);
    margin: 2.5em 0;
  }
  .prose-murikah table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95em;
  }
  .prose-murikah th,
  .prose-murikah td {
    border-bottom: 1px solid var(--color-hairline);
    padding: 0.6em 0.5em;
    text-align: left;
  }
  .prose-murikah th {
    color: var(--color-navy);
    font-weight: 600;
  }
</style>
