---
/**
 * CtaSection — the closing call-to-action band. This is the page's "end" moment
 * (Peak–End rule): a single, strong, gold primary action on a navy field.
 */
import Section from './Section.astro';
import Button from './Button.astro';
import { PRIMARY_CTA } from '@/site.config';

interface Props {
  eyebrow?: string;
  title: string;
  body?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  id?: string;
}

const {
  eyebrow,
  title,
  body,
  primaryLabel = PRIMARY_CTA.label,
  primaryHref = PRIMARY_CTA.href,
  secondaryLabel,
  secondaryHref,
  id,
} = Astro.props;
---

<Section tone="navy" id={id}>
  <div class="mx-auto max-w-2xl text-center">
    {eyebrow && <p class="text-sm font-semibold tracking-widest text-gold uppercase">{eyebrow}</p>}
    <h2 class="mt-3 text-3xl text-white sm:text-4xl">{title}</h2>
    {body && <p class="mx-auto mt-4 max-w-prose text-paper/85">{body}</p>}
    <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <Button href={primaryHref} variant="primary" size="lg">{primaryLabel}</Button>
      {
        secondaryLabel && secondaryHref && (
          <Button
            href={secondaryHref}
            variant="ghost"
            size="lg"
            class="text-white ring-white/30 hover:bg-white/10"
          >
            {secondaryLabel}
          </Button>
        )
      }
    </div>
  </div>
</Section>
