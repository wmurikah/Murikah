---
/**
 * CtaSection, the closing call-to-action band. This is the page's "end" moment
 * (peak-end rule): a single, strong, gold primary action on a navy field.
 */
import Section from './Section.astro';
import Button from './Button.astro';
import { PRIMARY_CTA } from '@/site.config';

interface Props {
  eyebrow?: string;
  title: string;
  body?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  id?: string;
}

const {
  eyebrow,
  title,
  body,
  primaryLabel = PRIMARY_CTA.label,
  primaryHref = PRIMARY_CTA.href,
  secondaryLabel,
  secondaryHref,
  id,
} = Astro.props;
---

<Section tone="navy-rich" id={id} class="relative overflow-hidden">
  {/* The signature light, placed once behind the closing statement. */}
  <div
    aria-hidden="true"
    class="aperture top-0 left-1/2 h-[26rem] w-[34rem] -translate-x-1/2 -translate-y-1/2"
  >
  </div>
  <div class="reveal relative mx-auto max-w-2xl text-center">
    {eyebrow && <p class="eyebrow is-centred">{eyebrow}</p>}
    <h2
      class="mt-5 font-serif text-[length:var(--text-title)] leading-[1.06] font-semibold tracking-[-0.02em] text-balance text-white"
    >
      {title}
    </h2>
    {body && <p class="mx-auto mt-5 max-w-prose text-lg text-paper/80">{body}</p>}
    <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <Button href={primaryHref} variant="primary" size="lg">{primaryLabel}</Button>
      {
        secondaryLabel && secondaryHref && (
          <Button
            href={secondaryHref}
            variant="ghost"
            size="lg"
            class="text-white ring-white/25 hover:bg-white/10 hover:ring-white/40"
          >
            {secondaryLabel}
          </Button>
        )
      }
    </div>
  </div>
</Section>
