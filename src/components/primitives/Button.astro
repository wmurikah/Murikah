---
/**
 * Button, renders an <a> when `href` is set, otherwise a <button>.
 *
 * Variants:
 *  - primary  → the ONE strong action: a deep navy fill with ivory text and a
 *    scarce aged-brass hairline that warms on hover. On dark surfaces the
 *    `.on-dark .btn-primary` rule in global.css inverts it to an ivory fill with
 *    navy text, so the same variant reads on ivory and on navy.
 *  - secondary→ quiet outline on a porcelain surface, ink text.
 *  - ghost    → the quietest, transparent with a hairline.
 *
 * Brass is an accent only, never a large fill (see the brand palette). The
 * stable btn-* class on each variant is the hook the dark-surface rule targets.
 *
 * Fitts's Law: min tap target 44×44px (min-h 2.75rem + generous padding).
 * Doherty Threshold: 200ms transition gives instant hover/active feedback.
 */
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  [key: string]: unknown;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  class: className,
  ...rest
} = Astro.props;

const base =
  'group/btn inline-flex items-center justify-center gap-2 rounded-btn font-medium text-center no-underline transition-[transform,background-color,box-shadow,color] duration-200 ease-[cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-0.5 active:translate-y-0 disabled:pointer-events-none disabled:opacity-60';

const sizeClass: Record<string, string> = {
  md: 'min-h-[2.75rem] px-5 py-2.5 text-[0.9375rem]',
  lg: 'min-h-[3.25rem] px-6 py-3 text-[1rem]',
};

// The one strong action is a deep navy button with a scarce brass hairline that
// warms on hover; the others stay quiet outlines. The btn-* class is a stable
// hook for the dark-surface inversion in global.css.
const variantClass: Record<string, string> = {
  primary:
    'btn-primary bg-navy text-paper shadow-card ring-1 ring-inset ring-brass/30 hover:bg-obsidian hover:ring-brass/70 hover:shadow-lift active:bg-obsidian',
  secondary:
    'btn-secondary bg-surface text-navy ring-1 ring-inset ring-hairline hover:bg-stone hover:ring-slate/40',
  ghost:
    'btn-ghost bg-transparent text-navy ring-1 ring-inset ring-hairline hover:bg-stone hover:ring-slate/40',
};

const cls = [base, sizeClass[size], variantClass[variant], className];
---

{
  href ? (
    <a href={href} class:list={cls} {...rest}>
      <slot />
    </a>
  ) : (
    <button type={type} class:list={cls} {...rest}>
      <slot />
    </button>
  )
}
