---
/**
 * Logo lockup: the Murikah "M" monogram, a fine brass divider and the "MURIKAH"
 * wordmark in tracked caps, recreated in code to match the brand lockups
 * (docs/brand-assets.md). It is a crisp, transparent SVG plus text, so it stays
 * sharp at every size and recolours by surface rather than shipping a raster
 * lockup into the page chrome:
 *   - monogram strokes and wordmark inherit `currentColor` (navy on light,
 *     ivory on dark via `tone`)
 *   - the one aged-brass diagonal, and the divider, are the scarce accent.
 *
 * `tone="light"` is for dark surfaces (the dark header and footer). Set
 * `withWordmark={false}` for the compact monogram-only mark.
 */
interface Props {
  tone?: 'dark' | 'light';
  withWordmark?: boolean;
  class?: string;
}
const { tone = 'dark', withWordmark = true, class: className } = Astro.props;

// One colour drives both the monogram strokes (currentColor) and the wordmark.
const color = tone === 'light' ? 'text-paper' : 'text-navy';
---

<span class:list={['inline-flex items-center gap-3', color, className]}>
  <svg
    width="30"
    height="30"
    viewBox="0 0 32 32"
    fill="none"
    aria-hidden="true"
    focusable="false"
    class="shrink-0"
  >
    {/* The M: left bar, valley, right bar. Strokes take the current colour. */}
    <path
      d="M4 27 V6 L16 20.5 L28 6 V27"
      stroke="currentColor"
      stroke-width="4.6"
      stroke-linejoin="round"
      stroke-linecap="round"></path>
    {/* The single aged-brass accent: a fine diagonal in the right of the valley. */}
    <path d="M26.4 9 L18.4 18.7" stroke="#A9822E" stroke-width="2.4" stroke-linecap="round"></path>
  </svg>
  {
    withWordmark && (
      <Fragment>
        <span class="h-6 w-px shrink-0 bg-brass/70" aria-hidden="true" />
        <span class="text-lg leading-none font-semibold tracking-[0.2em] uppercase">Murikah</span>
      </Fragment>
    )
  }
</span>
