---
/**
 * Logo: the Murikah "M" monogram (a bold geometric M with a single aged-brass
 * diagonal accent) next to the "Murikah" wordmark in the neutral brand sans.
 *
 * The monogram is a crisp, transparent SVG that adapts to its surface: the M
 * strokes and wordmark inherit `currentColor` (navy on light, ivory on dark via
 * `tone`), and the one brass diagonal is the scarce accent. No tile, no filled
 * dot; the mark never interrupts the name, which reads plainly as "Murikah".
 *
 * `tone="light"` is for dark surfaces (the dark header and footer).
 */
interface Props {
  tone?: 'dark' | 'light';
  withWordmark?: boolean;
  class?: string;
}
const { tone = 'dark', withWordmark = true, class: className } = Astro.props;

// One colour drives both the monogram strokes (currentColor) and the wordmark.
const color = tone === 'light' ? 'text-paper' : 'text-navy';
---

<span class:list={['inline-flex items-center gap-2.5', color, className]}>
  <svg
    width="30"
    height="30"
    viewBox="0 0 32 32"
    fill="none"
    aria-hidden="true"
    focusable="false"
    class="shrink-0"
  >
    {/* The M: left bar, valley, right bar. Strokes take the current colour. */}
    <path
      d="M4 27 V6 L16 20.5 L28 6 V27"
      stroke="currentColor"
      stroke-width="4.6"
      stroke-linejoin="round"
      stroke-linecap="round"></path>
    {/* The single aged-brass accent: a fine diagonal in the right of the valley. */}
    <path d="M26.4 9 L18.4 18.7" stroke="#A9822E" stroke-width="2.4" stroke-linecap="round"></path>
  </svg>
  {withWordmark && <span class="text-xl font-semibold tracking-[-0.02em]">Murikah</span>}
</span>
