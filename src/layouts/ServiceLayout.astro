---
/**
 * ServiceLayout, the consistent shell for the six service pages. It renders the
 * hero (eyebrow, H1, answer-first opener, CTAs), the Service and BreadcrumbList
 * JSON-LD, then the page's bespoke body via <slot />, then the FAQ block (with
 * matching FAQPage JSON-LD) and the closing CTA. Each page supplies its own
 * sections, so the structure stays familiar (Jakob's Law) while the copy is
 * specific to each line.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/primitives/Section.astro';
import Button from '@/components/primitives/Button.astro';
import Faq from '@/components/primitives/Faq.astro';
import Breadcrumb from '@/components/primitives/Breadcrumb.astro';
import CtaSection from '@/components/primitives/CtaSection.astro';
import ServiceSchema from '@/components/schema/Service.astro';
import FaqPageSchema from '@/components/schema/FaqPage.astro';
import { SERVICES, PRIMARY_CTA } from '@/site.config';
import type { FaqItem } from '@/lib/types';

interface Cta {
  label: string;
  href: string;
}

interface Props {
  /** Service slug, pulls name and serviceType from site.config. */
  slug: string;
  /** Primary phrase for the page <title> (Murikah is appended). */
  metaTitle: string;
  metaDescription: string;
  /** H1. */
  heading: string;
  /** Answer-first opener, shown prominently under the H1. */
  intro: string;
  primaryCta?: Cta;
  secondaryCta?: Cta;
  faqs: FaqItem[];
  closingTitle: string;
  closingBody: string;
}

const {
  slug,
  metaTitle,
  metaDescription,
  heading,
  intro,
  primaryCta = { label: PRIMARY_CTA.label, href: PRIMARY_CTA.href },
  secondaryCta,
  faqs,
  closingTitle,
  closingBody,
} = Astro.props;

const service = SERVICES.find((s) => s.slug === slug);
if (!service) throw new Error(`Unknown service slug: ${slug}`);

const crumbs = [
  { label: 'Home', href: '/' },
  { label: service.fullName, href: service.href },
];
---

<BaseLayout titleFull={metaTitle} description={metaDescription}>
  <ServiceSchema
    slot="head"
    name={service.fullName}
    description={service.summary}
    serviceType={service.serviceType}
    path={service.href}
  />

  {
    /* Hero, the page's opening peak. The answer-first opener doubles as the
      direct answer that search and AI engines can quote. */
  }
  <Section
    tone="surface"
    aria-labelledby="page-title"
    class="relative overflow-hidden border-b border-hairline"
  >
    {/* A single, faint touch of the signature light, warm in the corner. */}
    <div aria-hidden="true" class="aperture -top-40 -right-24 h-[30rem] w-[40rem] opacity-50"></div>
    <div class="relative max-w-3xl">
      <Breadcrumb items={crumbs} class="mb-7" />
      <p class="eyebrow">{service.name}</p>
      <h1
        id="page-title"
        class="mt-5 font-serif text-[length:var(--text-title)] leading-[1.05] font-semibold tracking-[-0.02em] text-balance text-navy"
      >
        {heading}
      </h1>
      <p class="mt-6 max-w-2xl text-xl text-slate">{intro}</p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <Button href={primaryCta.href} variant="primary" size="lg">{primaryCta.label}</Button>
        {
          secondaryCta && (
            <Button href={secondaryCta.href} variant="ghost" size="lg">
              {secondaryCta.label}
            </Button>
          )
        }
      </div>
    </div>
  </Section>

  {/* Page-specific body. */}
  <slot />

  {/* FAQ, progressive disclosure plus FAQPage schema from the same data. */}
  <Section tone="surface" aria-labelledby="faq" class="border-t border-hairline">
    <p class="eyebrow">Questions</p>
    <h2
      id="faq"
      class="mt-5 font-serif text-[length:var(--text-title)] leading-[1.06] font-semibold tracking-[-0.02em] text-navy"
    >
      Frequently asked questions
    </h2>
    <Faq items={faqs} class="mt-8 max-w-3xl" />
    <FaqPageSchema items={faqs} />
  </Section>

  <CtaSection
    title={closingTitle}
    body={closingBody}
    primaryLabel={primaryCta.label}
    primaryHref={primaryCta.href}
  />
</BaseLayout>
