---
/**
 * BaseLayout, the document shell for every page: <head> (fonts, SEO, global
 * Organization JSON-LD), the skip link, header, <main>, and footer. Semantic
 * landmarks throughout (header/nav/main/footer) for assistive tech.
 *
 * Fonts are self-hosted via Fontsource (font-display: swap) and the two woff2
 * files are preloaded to protect LCP and prevent late-font layout shift.
 */
import '@fontsource-variable/outfit/wght.css';
import '@fontsource-variable/fraunces/wght.css';
import '@/styles/global.css';

// `?url` → fingerprinted asset URLs for <link rel="preload">.
import outfitWoff2 from '@fontsource-variable/outfit/files/outfit-latin-wght-normal.woff2?url';
import frauncesWoff2 from '@fontsource-variable/fraunces/files/fraunces-latin-wght-normal.woff2?url';

import Seo from '@/components/Seo.astro';
import OrganizationSchema from '@/components/schema/Organization.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Assistant from '@/components/assistant/Assistant.tsx';
import { SITE } from '@/site.config';

interface Props {
  title?: string;
  titleFull?: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    tags?: string[];
  };
  /** Optional classes on <main>. */
  mainClass?: string;
}

const { mainClass, ...seo } = Astro.props;
---

<!doctype html>
<html lang={SITE.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#0B1733" />
    <meta name="generator" content={Astro.generator} />

    {/* Preload the two self-hosted fonts (LCP + no layout shift). */}
    <link rel="preload" href={outfitWoff2} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={frauncesWoff2} as="font" type="font/woff2" crossorigin="anonymous" />

    <Seo {...seo} />
    <OrganizationSchema />

    {/* Pages may inject extra <head> tags (e.g. page-specific schema). */}
    <slot name="head" />
  </head>
  <body>
    {/* Skip link, first focusable element (keyboard + screen-reader users). */}
    <a href="#main" class="skip-link">Skip to content</a>

    <Header />

    <main id="main" class:list={[mainClass]}>
      <slot />
    </main>

    <Footer />

    {
      /* Site-wide AI assistant. Loaded lazily (client:idle) so it never blocks
        the page or shifts layout; it is fixed-positioned and out of flow. */
    }
    <Assistant client:idle />
  </body>
</html>
