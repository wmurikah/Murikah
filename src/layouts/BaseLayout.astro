---
/**
 * BaseLayout, the document shell for every page: <head> (fonts, SEO, global
 * Organization JSON-LD), the skip link, header, <main>, and footer. Semantic
 * landmarks throughout (header/nav/main/footer) for assistive tech.
 *
 * The primary sans is a neutral, Apple-adjacent stack: Apple devices render
 * native San Francisco via -apple-system, everything else gets bundled Inter.
 * Inter is self-hosted via Fontsource (font-display: swap) and its variable
 * woff2 is preloaded to protect LCP and prevent late-font layout shift.
 */
import '@fontsource-variable/inter/wght.css';
import '@/styles/global.css';

// `?url` → fingerprinted asset URL for <link rel="preload">.
import interWoff2 from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';

import Seo from '@/components/Seo.astro';
import OrganizationSchema from '@/components/schema/Organization.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { SITE } from '@/site.config';

interface Props {
  title?: string;
  titleFull?: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    tags?: string[];
  };
  /** Optional classes on <main>. */
  mainClass?: string;
}

const { mainClass, ...seo } = Astro.props;
---

<!doctype html>
<html lang={SITE.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {
      /* Mark JS as available before paint so reveal/motion states only apply
        when they can be undone. Without JS, everything is visible. */
    }
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#0B1733" />
    <meta name="generator" content={Astro.generator} />

    {/* Preload the two self-hosted fonts (LCP + no layout shift). */}
    <link rel="preload" href={interWoff2} as="font" type="font/woff2" crossorigin="anonymous" />

    <Seo {...seo} />
    <OrganizationSchema />

    {/* Pages may inject extra <head> tags (e.g. page-specific schema). */}
    <slot name="head" />
  </head>
  <body>
    {/* Skip link, first focusable element (keyboard + screen-reader users). */}
    <a href="#main" class="skip-link">Skip to content</a>

    <Header />

    <main id="main" class:list={[mainClass]}>
      <slot />
    </main>

    <Footer />

    {
      /* Scroll reveals: add `reveal` to any element to fade it up once on entry.
        Falls back to visible without IntersectionObserver; disabled by the
        reduced-motion rule in global.css. */
    }
    <script is:inline>
      (function () {
        const els = document.querySelectorAll('.reveal');
        if (!els.length) return;
        if (!('IntersectionObserver' in window)) {
          for (let i = 0; i < els.length; i++) els[i].classList.add('is-visible');
          return;
        }
        const io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.08 },
        );
        els.forEach(function (el) {
          io.observe(el);
        });
      })();
    </script>
  </body>
</html>
