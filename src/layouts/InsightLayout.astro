---
/**
 * InsightLayout, the layout for guides. Encodes the content conventions:
 * answer-first opener shown prominently, semantic H2/H3 from the body, an FAQ
 * block that emits matching FAQPage JSON-LD, BlogPosting and BreadcrumbList
 * schema, the company byline (Murikah authors the guides, no individual is
 * named), a related-guides block, and a closing CTA to the parent service.
 */
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/primitives/Section.astro';
import Prose from '@/components/primitives/Prose.astro';
import Card from '@/components/primitives/Card.astro';
import FeatureGrid from '@/components/primitives/FeatureGrid.astro';
import Faq from '@/components/primitives/Faq.astro';
import Breadcrumb from '@/components/primitives/Breadcrumb.astro';
import CtaSection from '@/components/primitives/CtaSection.astro';
import FaqPageSchema from '@/components/schema/FaqPage.astro';
import AuthorByline from '@/components/AuthorByline.astro';
import { SITE, SERVICES } from '@/site.config';
import { organizationRef, organizationId } from '@/lib/schema';
import { formatDate, isoDate } from '@/lib/format';

interface Props {
  entry: CollectionEntry<'insights'>;
}

const { entry } = Astro.props;
const { title, description, question, summary, pubDate, updatedDate, tags, category, service } =
  entry.data;

const url = new URL(`/insights/${entry.id}/`, SITE.url).href;
const lead = summary ?? description;

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Insights', href: '/insights' },
  { label: title, href: `/insights/${entry.id}/` },
];

// Related guides: explicit `related` slugs first, then same-category siblings.
const all = await getCollection('insights', ({ data }) => !data.draft);
const others = all.filter((g) => g.id !== entry.id);
const explicit = entry.data.related
  .map((slug) => others.find((g) => g.id === slug))
  .filter((g): g is CollectionEntry<'insights'> => Boolean(g));
const sameCategory = others.filter((g) => g.data.category && g.data.category === category);
const related = [...new Set([...explicit, ...sameCategory])].slice(0, 2);

// Parent service for the up-link and CTA target.
const parentService = service ? SERVICES.find((s) => s.slug === service) : undefined;

// BlogPosting JSON-LD. Murikah (the Organization) is the author and publisher.
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: organizationRef(),
  publisher: {
    '@type': 'Organization',
    '@id': organizationId,
    name: SITE.name,
    logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', SITE.url).href },
  },
  image: new URL(entry.data.ogImage ?? SITE.defaultOgImage, SITE.url).href,
  mainEntityOfPage: url,
  ...(category ? { articleSection: category } : {}),
  ...(tags.length ? { keywords: tags.join(', ') } : {}),
};
---

<BaseLayout
  title={title}
  description={description}
  image={entry.data.ogImage}
  type="article"
  article={{
    publishedTime: pubDate.toISOString(),
    modifiedTime: (updatedDate ?? pubDate).toISOString(),
    author: SITE.name,
    tags,
  }}
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(articleSchema)}
    slot="head"
  />

  {/* Guide header, a calm editorial opening on a single centred axis. */}
  <Section tone="surface" aria-labelledby="page-title" class="border-b border-hairline">
    <div class="mx-auto max-w-3xl">
      <Breadcrumb items={crumbs} class="mb-8" />
      {category && <p class="eyebrow">{category}</p>}
      <h1
        id="page-title"
        class="mt-5 font-serif text-[length:var(--text-title)] leading-[1.05] font-semibold tracking-[-0.02em] text-balance text-navy"
      >
        {question ?? title}
      </h1>
      <p class="mt-6 text-xl text-slate">{lead}</p>

      <hr class="beam mt-9 border-0" />
      <div class="mt-6 flex flex-wrap items-center justify-between gap-x-6 gap-y-3">
        <AuthorByline />
        <p class="text-sm text-slate">
          <time datetime={isoDate(pubDate)}>{formatDate(pubDate)}</time>
          {
            updatedDate && (
              <>
                {' '}
                · Updated <time datetime={isoDate(updatedDate)}>{formatDate(updatedDate)}</time>
              </>
            )
          }
        </p>
      </div>
    </div>
  </Section>

  <Section tone="paper">
    <div class="mx-auto max-w-3xl">
      <Prose>
        <slot />
      </Prose>

      {
        entry.data.faqs && entry.data.faqs.length > 0 && (
          <div class="mt-16">
            <Faq items={entry.data.faqs} title="Frequently asked questions" />
            <FaqPageSchema items={entry.data.faqs} />
          </div>
        )
      }

      {
        parentService && (
          <p class="mt-12">
            <a
              href={parentService.href}
              class="font-medium text-blue no-underline hover:text-blue-deep hover:underline"
            >
              Read more about {parentService.fullName} &rarr;
            </a>
          </p>
        )
      }
    </div>
  </Section>

  {
    related.length > 0 && (
      <Section tone="surface" aria-labelledby="related" class="border-t border-hairline">
        <p class="eyebrow">Keep reading</p>
        <h2
          id="related"
          class="mt-5 font-serif text-[length:var(--text-title)] leading-[1.06] font-semibold tracking-[-0.02em] text-navy"
        >
          Related guides
        </h2>
        <FeatureGrid cols={2} class="mt-10">
          {related.map((g) => (
            <Card href={`/insights/${g.id}/`} class="flex flex-col">
              {g.data.category && <p class="eyebrow text-xs">{g.data.category}</p>}
              <h3 class="mt-3 text-lg text-navy">{g.data.title}</h3>
              <p class="mt-2 text-slate">{g.data.description}</p>
            </Card>
          ))}
        </FeatureGrid>
      </Section>
    )
  }

  <CtaSection
    eyebrow="Book a demo"
    title="Put this into practice"
    body="Book a demo and we will map this to your organisation, your regulator and your board."
    secondaryLabel="Read more insights"
    secondaryHref="/insights"
  />
</BaseLayout>
