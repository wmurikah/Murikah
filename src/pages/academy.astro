---
export const prerender = true;

import ServiceLayout from '@/layouts/ServiceLayout.astro';
import Section from '@/components/primitives/Section.astro';
import Card from '@/components/primitives/Card.astro';
import FeatureGrid from '@/components/primitives/FeatureGrid.astro';
import type { FaqItem } from '@/lib/types';

const tracks = [
  {
    title: 'Certification preparation',
    body: 'CISA preparation for information systems auditors, and ISO 42001 awareness and lead-auditor readiness for teams taking on AI governance.',
  },
  {
    title: 'Practical masterclasses',
    body: 'AI and automation for finance, internal audit for the mid-market, and data protection for boards. Short, applied, and built on real work.',
  },
  {
    title: 'In-house team enablement',
    body: 'We train your people on the job as part of a co-sourced engagement, so capability stays in the building when we step back.',
  },
];

const faqs: FaqItem[] = [
  {
    question: 'What courses does Academy offer?',
    answer:
      'Two tracks. Certification preparation covers CISA and ISO 42001 awareness and lead-auditor readiness. Practical masterclasses cover AI and automation for finance, internal audit for the mid-market, and data protection for boards. We also run in-house enablement as part of co-sourcing, training your team while the work gets done.',
  },
  {
    question: 'Do you prepare people for the CISA exam?',
    answer:
      'Yes. CISA, the Certified Information Systems Auditor credential, is one of our core preparation programmes. Sessions are taught by practitioners and grounded in real audit work, not just exam theory.',
  },
  {
    question: 'Can you train our whole team in-house?',
    answer:
      'Yes. We deliver cohort training for a single team or a whole function, tailored to your sector and systems. In-house enablement also comes built into co-sourced assurance, so your team learns the method as we apply it together.',
  },
  {
    question: 'Are sessions practical or theoretical?',
    answer:
      'Practical first. We teach from real audits, real findings and real automation, so people can apply what they learn the next day. Theory is covered where a certification requires it, but the goal is capability your organisation can use, not certificates on a wall.',
  },
];
---

<ServiceLayout
  slug="academy"
  metaTitle="Training in audit, AI governance and automation | Murikah"
  metaDescription="Practical training and certification prep: CISA, ISO 42001 awareness, and masterclasses in AI and automation for finance and internal audit."
  heading="Training that turns your team into the control."
  intro="Academy offers certification preparation and practical masterclasses for the people who run assurance and risk. Certification preparation covers CISA and ISO 42001 awareness and lead-auditor readiness. Masterclasses cover AI and automation for finance, internal audit for the mid-market, and data protection for boards. We also deliver in-house team enablement as part of co-sourcing, so your people build real capability while the audit work gets done. Every session is taught by practitioners who do this work day to day."
  primaryCta={{ label: 'Enquire about training', href: '/contact' }}
  secondaryCta={{ label: 'See Advisory', href: '/advisory' }}
  faqs={faqs}
  closingTitle="Build capability your organisation keeps"
  closingBody="Tell us your team and your goals, and we will propose the right preparation or masterclass."
>
  <Section tone="paper" aria-labelledby="tracks">
    <h2
      id="tracks"
      class="font-serif text-[length:var(--text-title)] leading-[1.08] font-semibold tracking-[-0.02em] text-navy"
    >
      What we teach
    </h2>
    <FeatureGrid cols={3} class="mt-8">
      {
        tracks.map((t) => (
          <Card>
            <h3 class="text-lg text-navy">{t.title}</h3>
            <p class="mt-2 text-slate">{t.body}</p>
          </Card>
        ))
      }
    </FeatureGrid>
  </Section>

  <Section tone="surface" aria-labelledby="formats">
    <div class="grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <h2
          id="formats"
          class="font-serif text-[length:var(--text-title)] leading-[1.08] font-semibold tracking-[-0.02em] text-navy"
        >
          Who it is for, and how it runs
        </h2>
      </div>
      <div class="lg:col-span-7">
        <p class="max-w-prose text-ink">
          Academy is for internal auditors building credentials, risk and compliance professionals,
          and finance and operations teams adopting AI responsibly. We run cohort sessions for
          individuals and closed sessions for a single team or function, in person or online, scoped
          to your sector and systems.
        </p>
        <p class="mt-4 max-w-prose text-ink">
          Specific dates are published ahead of each intake. {'{{ACADEMY: confirm upcoming dates}}'}
        </p>
      </div>
    </div>
  </Section>

  <Section tone="paper" aria-labelledby="related">
    <h2
      id="related"
      class="font-serif text-[length:var(--text-title)] leading-[1.08] font-semibold tracking-[-0.02em] text-navy"
    >
      Related reading
    </h2>
    <ul class="mt-6 grid max-w-3xl gap-3">
      <li>
        <a href="/insights/iso-42001-readiness" class="font-medium text-blue hover:text-blue-deep">
          ISO 42001 readiness: what organisations actually need to do
        </a>
      </li>
      <li>
        <a
          href="/insights/kenya-data-protection-act"
          class="font-medium text-blue hover:text-blue-deep"
        >
          The Kenya Data Protection Act: what controllers and processors must do
        </a>
      </li>
    </ul>
  </Section>
</ServiceLayout>
