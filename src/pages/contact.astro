---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/primitives/Section.astro';
import Button from '@/components/primitives/Button.astro';
import Breadcrumb from '@/components/primitives/Breadcrumb.astro';
import { SITE, FOUNDER } from '@/site.config';

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Contact', href: '/contact' },
];

// No-JS feedback: the endpoint redirects to /contact?status=… on form posts.
const status = Astro.url.searchParams.get('status');
const statusMap: Record<string, { kind: 'success' | 'error'; msg: string }> = {
  ok: { kind: 'success', msg: "Thanks, we'll be in touch shortly." },
  invalid: { kind: 'error', msg: 'Please check your details and try again.' },
  ratelimited: { kind: 'error', msg: 'Too many submissions. Please try again later.' },
  error: { kind: 'error', msg: 'Something went wrong. Please email us directly.' },
};
const initialStatus = status ? statusMap[status] : undefined;

const field =
  'mt-1.5 block w-full min-h-[2.75rem] rounded-btn border border-hairline bg-surface px-3.5 py-2.5 text-ink placeholder:text-slate/60 aria-[invalid]:border-status-high';
const labelCls = 'block text-sm font-medium text-navy';
---

<BaseLayout
  titleFull="Contact Murikah | Book a demo or an assurance conversation"
  description="Talk to Murikah about co-sourced internal audit, Audit OS, AI governance or training. Tell us about your organisation and we respond within two working days."
>
  <Section tone="surface" aria-labelledby="page-title" class="border-b border-hairline">
    <Breadcrumb items={crumbs} class="mb-6" />
    <p class="text-sm font-semibold tracking-widest text-gold uppercase">Contact</p>
    <h1 id="page-title" class="mt-3 max-w-3xl text-4xl text-balance sm:text-5xl">
      Book a demo or start a conversation
    </h1>
    <p class="mt-5 max-w-prose text-lg text-slate">
      Tell us about your organisation and what you are trying to achieve, whether that is co-sourced
      internal audit, Audit OS, AI governance or training. We will read your message and respond
      within two working days with the right next step, usually a short call.
    </p>
  </Section>

  <Section tone="paper">
    <div class="grid gap-12 lg:grid-cols-12">
      {/* Form */}
      <div class="lg:col-span-7">
        <div
          id="form-status"
          role="status"
          aria-live="polite"
          class="form-status mb-6"
          data-kind={initialStatus?.kind}
          hidden={!initialStatus}
        >
          {initialStatus?.msg}
        </div>

        <form id="contact-form" action="/api/contact" method="post" novalidate class="grid gap-5">
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="name" class={labelCls}
                >Name <span aria-hidden="true" class="text-status-high">*</span></label
              >
              <input
                id="name"
                name="name"
                type="text"
                required
                autocomplete="name"
                class={field}
                aria-describedby="name-error"
              />
              <p id="name-error" data-error-for="name" class="field-error" hidden></p>
            </div>
            <div>
              <label for="organisation" class={labelCls}>Organisation</label>
              <input
                id="organisation"
                name="organisation"
                type="text"
                autocomplete="organization"
                class={field}
              />
            </div>
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="role" class={labelCls}>Role</label>
              <input
                id="role"
                name="role"
                type="text"
                autocomplete="organization-title"
                class={field}
              />
            </div>
            <div>
              <label for="email" class={labelCls}
                >Email <span aria-hidden="true" class="text-status-high">*</span></label
              >
              <input
                id="email"
                name="email"
                type="email"
                required
                autocomplete="email"
                class={field}
                aria-describedby="email-error"
              />
              <p id="email-error" data-error-for="email" class="field-error" hidden></p>
            </div>
          </div>

          <div>
            <label for="message" class={labelCls}
              >Message <span aria-hidden="true" class="text-status-high">*</span></label
            >
            <textarea
              id="message"
              name="message"
              rows="6"
              required
              class={`${field} resize-y`}
              aria-describedby="message-error"></textarea>
            <p id="message-error" data-error-for="message" class="field-error" hidden></p>
          </div>

          {/* Honeypot, hidden from people, tempting to bots. */}
          <div class="hidden" aria-hidden="true">
            <label for="company_website">Leave this field empty</label>
            <input
              id="company_website"
              name="company_website"
              type="text"
              tabindex="-1"
              autocomplete="off"
            />
          </div>

          <div class="flex items-center gap-4">
            <Button type="submit" variant="primary" size="lg">Send message</Button>
            <p class="text-sm text-slate">We respond within two working days.</p>
          </div>
        </form>
      </div>

      {/* Aside */}
      <aside class="lg:col-span-5">
        <div class="rounded-card bg-surface p-7 ring-1 ring-hairline/70">
          <h2 class="text-xl">Prefer email?</h2>
          <p class="mt-2 text-slate">
            Reach us directly at
            <a href={`mailto:${SITE.email}`} class="font-medium text-blue hover:text-blue-deep"
              >{SITE.email}</a
            >.
          </p>
          <hr class="my-6 border-hairline" />
          <h2 class="text-xl">Why teams choose Murikah</h2>
          <ul class="mt-3 flex flex-wrap gap-2" aria-label="Credentials">
            {
              FOUNDER.credentials.map((c) => (
                <li class="rounded-full bg-paper px-3 py-1 text-sm text-ink ring-1 ring-hairline">
                  {c}
                </li>
              ))
            }
          </ul>
          <p class="mt-4 text-sm text-slate">
            Independent, certified and platform-backed assurance, led by a CISA and ISO 42001 Lead
            Auditor.
          </p>
        </div>
      </aside>
    </div>
  </Section>
</BaseLayout>

<style>
  /* Form feedback is the one sanctioned use of status colours in the marketing
     UI, functional validation, conveyed by text + icon + a thin accent, never
     colour alone (WCAG). */
  .form-status {
    border-radius: var(--radius-btn);
    border-left: 3px solid var(--color-hairline);
    background: var(--color-surface);
    padding: 0.85rem 1rem;
    box-shadow: var(--shadow-card);
    color: var(--color-ink);
  }
  .form-status[data-kind='success'] {
    border-left-color: var(--color-status-low);
  }
  .form-status[data-kind='error'] {
    border-left-color: var(--color-status-high);
  }
  .form-status[data-kind='pending'] {
    border-left-color: var(--color-blue);
  }
  .field-error {
    margin-top: 0.4rem;
    font-size: 0.875rem;
    color: var(--color-status-high);
  }
</style>

<script>
  // Progressive enhancement: inline, immediate feedback (Doherty Threshold).
  // Without JS the form posts normally and the endpoint redirects with ?status.
  function initContactForm() {
    const form = document.querySelector<HTMLFormElement>('#contact-form');
    if (!form) return;
    const statusEl = document.querySelector<HTMLElement>('#form-status');
    const submit = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const submitLabel = submit?.textContent ?? 'Send message';

    const clearErrors = () => {
      form.querySelectorAll<HTMLElement>('[data-error-for]').forEach((el) => {
        el.hidden = true;
        el.textContent = '';
      });
      form
        .querySelectorAll<HTMLElement>('[aria-invalid]')
        .forEach((el) => el.removeAttribute('aria-invalid'));
    };

    const setError = (fieldName: string, message: string) => {
      const el = form.querySelector<HTMLElement>(`[data-error-for="${fieldName}"]`);
      if (el) {
        el.textContent = message;
        el.hidden = false;
      }
      form.querySelector(`[name="${fieldName}"]`)?.setAttribute('aria-invalid', 'true');
    };

    const setStatus = (message: string, kind: string) => {
      if (!statusEl) return;
      statusEl.textContent = message;
      statusEl.dataset.kind = kind;
      statusEl.hidden = false;
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearErrors();
      setStatus('Sending…', 'pending');
      if (submit) {
        submit.disabled = true;
        submit.textContent = 'Sending…';
      }

      try {
        const payload = Object.fromEntries(new FormData(form));
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { Accept: 'application/json', 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = (await res.json().catch(() => ({}))) as {
          ok?: boolean;
          message?: string;
          errors?: { field: string; message: string }[];
        };

        if (res.ok && data.ok) {
          form.reset();
          setStatus(data.message ?? "Thanks, we'll be in touch.", 'success');
        } else if (data.errors?.length) {
          data.errors.forEach((err) => setError(err.field, err.message));
          setStatus('Please check the highlighted fields.', 'error');
          form.querySelector<HTMLElement>('[aria-invalid="true"]')?.focus();
        } else {
          setStatus('Something went wrong. Please email us directly.', 'error');
        }
      } catch {
        setStatus('Network error. Please try again or email us.', 'error');
      } finally {
        if (submit) {
          submit.disabled = false;
          submit.textContent = submitLabel;
        }
      }
    });
  }

  initContactForm();
</script>
