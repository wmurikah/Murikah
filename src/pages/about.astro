---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/primitives/Section.astro';
import Button from '@/components/primitives/Button.astro';
import Card from '@/components/primitives/Card.astro';
import FeatureGrid from '@/components/primitives/FeatureGrid.astro';
import Stat from '@/components/primitives/Stat.astro';
import Breadcrumb from '@/components/primitives/Breadcrumb.astro';
import CtaSection from '@/components/primitives/CtaSection.astro';
import { SERVICES, FOUNDER } from '@/site.config';

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
];

// Placeholder values — finalised in the content pass.
const values = [
  {
    title: 'Independence',
    body: 'Assurance is only worth what its independence is worth. [placeholder]',
  },
  { title: 'Rigour', body: 'Methodology and evidence over opinion and theatre. [placeholder]' },
  {
    title: 'Accessible excellence',
    body: 'Big-4 rigour without the cost or rigidity. [placeholder]',
  },
];
---

<BaseLayout
  title="About"
  description="Murikah is an AI-native assurance and governance company, founded and led by a certified practitioner, serving regulated organisations across Africa."
>
  <Section tone="surface" aria-labelledby="page-title" class="border-b border-hairline">
    <Breadcrumb items={crumbs} class="mb-6" />
    <p class="text-sm font-semibold tracking-widest text-gold uppercase">About</p>
    <h1 id="page-title" class="mt-3 max-w-3xl text-4xl text-balance sm:text-5xl">
      Assurance, systems and intelligence — built for African organisations
    </h1>
    <p class="mt-5 max-w-prose text-lg text-slate">
      Murikah helps regulated, mid-market organisations run, prove and continuously improve their
      internal audit and their AI and system governance.
      <span class="text-slate/80">[placeholder]</span>
    </p>
  </Section>

  <Section tone="paper" aria-labelledby="approach">
    <div class="grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <h2 id="approach" class="text-2xl sm:text-3xl">Our approach</h2>
      </div>
      <div class="lg:col-span-7">
        <p class="max-w-prose text-ink">
          We pair experienced auditors with a working platform and AI assistance, so assurance is
          faster, more consistent and easier to prove — without Big-4 cost or lock-in.
          <span class="text-slate/80">[placeholder]</span>
        </p>
        <p class="mt-4 max-w-prose text-ink">
          Six connected lines of work let you start anywhere and grow into the rest.
          <span class="text-slate/80">[placeholder]</span>
        </p>
        <ul class="mt-6 grid gap-2.5 sm:grid-cols-2">
          {
            SERVICES.map((s) => (
              <li>
                <a
                  href={s.href}
                  class="font-medium text-blue no-underline hover:text-blue-deep hover:underline"
                >
                  {s.fullName}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </Section>

  {/* Founder — the E-E-A-T trust foundation (verifiable credentials only). */}
  <Section tone="surface" aria-labelledby="founder">
    <h2 id="founder" class="text-2xl sm:text-3xl">Founder</h2>
    <div class="mt-8 grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <p class="text-xl font-medium text-navy">{FOUNDER.name}</p>
        <p class="text-slate">{FOUNDER.role} · builder of Murikah Audit OS</p>
        <p class="mt-5 max-w-prose text-ink">
          Murikah is founded, built and led by {FOUNDER.name}, combining hands-on internal audit,
          information-security and AI-governance expertise with the engineering behind the platform. <span
            class="text-slate/80">[placeholder bio]</span
          >
        </p>
        <ul class="mt-6 flex flex-wrap gap-2" aria-label="Credentials">
          {
            FOUNDER.credentials.map((c) => (
              <li class="rounded-full bg-paper px-3 py-1 text-sm text-ink ring-1 ring-hairline">
                {c}
              </li>
            ))
          }
        </ul>
      </div>
      <div class="lg:col-span-5">
        <div class="grid gap-6 rounded-card bg-paper p-8 ring-1 ring-hairline/70">
          <Stat value="ISO 42001" label="AI management systems" hint="Lead Auditor" />
          <Stat value="ISO 27001" label="Information security" hint="Lead Auditor" />
          <Stat value="CISA" label="Information systems audit" hint="Certified" />
        </div>
      </div>
    </div>
  </Section>

  <Section tone="shade" aria-labelledby="values">
    <h2 id="values" class="text-2xl sm:text-3xl">What we stand for</h2>
    <FeatureGrid cols={3} class="mt-8">
      {
        values.map((v) => (
          <Card>
            <h3 class="text-xl text-navy">{v.title}</h3>
            <p class="mt-2 text-slate">{v.body}</p>
          </Card>
        ))
      }
    </FeatureGrid>
    <p class="mt-8">
      <Button href="/contact" variant="secondary">Work with us</Button>
    </p>
  </Section>

  <CtaSection
    title="Let's raise the standard of your assurance"
    body="Book a demo or start a conversation about your audit and governance goals. [placeholder]"
    secondaryLabel="Contact us"
    secondaryHref="/contact"
  />
</BaseLayout>
