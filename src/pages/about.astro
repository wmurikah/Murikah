---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/primitives/Section.astro';
import Button from '@/components/primitives/Button.astro';
import Breadcrumb from '@/components/primitives/Breadcrumb.astro';
import CtaSection from '@/components/primitives/CtaSection.astro';
import { SITE, STANDARDS } from '@/site.config';

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Who we are', href: '/about' },
  { label: 'About Murikah', href: '/about' },
];

const values = [
  {
    title: 'Independence',
    body: 'Assurance is only worth what its independence is worth. We protect ours, and yours.',
  },
  {
    title: 'Plain speaking',
    body: 'We write so a board can act on the first read. No jargon for its own sake.',
  },
  {
    title: 'Evidence over assertion',
    body: 'We show the work. Every conclusion is supported by something you can check.',
  },
];

const how = [
  {
    title: 'We work to recognised standards',
    body: 'Internal audit planned and run to the IIA Global Internal Audit Standards, with ISO/IEC 27001 and ISO/IEC 42001 framing our security and AI-governance work.',
  },
  {
    title: 'We leave the evidence behind',
    body: 'You keep the work papers, the findings and the system. When we step back, your function keeps running.',
  },
  {
    title: 'We price for the mid-market',
    body: 'Senior judgement and board-ready output without Big-4 fees or enterprise GRC licences.',
  },
];
---

<BaseLayout
  titleFull="About | Murikah"
  description="Murikah is an AI-native assurance and governance company. We help organisations run, prove and continuously improve their internal audit and AI governance."
>
  {/* Hero: a calm opening, with one faint touch of the signature light. */}
  <Section
    tone="surface"
    aria-labelledby="page-title"
    class="relative overflow-hidden border-b border-hairline"
  >
    <div aria-hidden="true" class="aperture -top-40 -right-24 h-[30rem] w-[40rem] opacity-50"></div>
    <div class="relative max-w-3xl">
      <Breadcrumb items={crumbs} class="mb-7" />
      <p class="eyebrow">About Murikah</p>
      <h1
        id="page-title"
        class="mt-5 text-[length:var(--text-title)] leading-[1.02] font-semibold tracking-[-0.015em] text-balance text-navy"
      >
        A company for clearer assurance, stronger systems and better decisions.
      </h1>
      <p class="mt-6 max-w-2xl text-xl text-slate">
        {SITE.meaning} We help organisations run internal audit and AI governance with evidence, calm
        workflows and board-ready outputs.
      </p>
    </div>
  </Section>

  {/* What we do, asymmetric. */}
  <Section tone="paper" aria-labelledby="what-we-do">
    <div class="grid gap-10 lg:grid-cols-12 lg:gap-16">
      <div class="reveal lg:col-span-5">
        <p class="eyebrow">What we do</p>
        <h2
          id="what-we-do"
          class="mt-5 font-serif text-[length:var(--text-title)] leading-[1.06] font-semibold tracking-[-0.02em] text-navy"
        >
          One company, the judgement and the software
        </h2>
      </div>
      <div class="reveal lg:col-span-7">
        <p class="max-w-prose text-lg text-ink">
          Murikah is an AI-native assurance and governance company. We help organisations run, prove
          and continuously improve their internal audit and their AI and system governance, at a
          fraction of the cost and rigidity of the Big 4 and enterprise governance, risk and
          compliance software.
        </p>
        <p class="mt-4 max-w-prose text-lg text-ink">
          We do it across six connected lines, from co-sourced internal audit and the Assurance
          Platform to advisory, training, automation and benchmarking. You can start anywhere and
          grow into the rest, with one team that brings both the judgement and the working software.
        </p>
      </div>
    </div>
  </Section>

  {
    /* Company statement, deliberately not founder-led. A calm paper band, set
      off from its neighbours by hairline rules rather than a dark fill. */
  }
  <Section tone="shade" class="border-y border-hairline">
    <div class="reveal mx-auto max-w-3xl text-center">
      <p class="eyebrow is-centred">Company, not personality</p>
      <p
        class="mt-6 text-[length:var(--text-title)] leading-[1.15] font-semibold tracking-[-0.01em] text-balance text-navy"
      >
        Murikah is built to stand on its methods, its evidence and its client outcomes, not on any
        individual biography.
      </p>
    </div>
  </Section>

  {/* Why now. */}
  <Section tone="surface" aria-labelledby="why-now" class="border-b border-hairline">
    <div class="reveal max-w-2xl">
      <p class="eyebrow">Why now</p>
      <h2
        id="why-now"
        class="mt-5 font-serif text-[length:var(--text-title)] leading-[1.06] font-semibold tracking-[-0.02em] text-navy"
      >
        The bar for assurance is rising
      </h2>
    </div>
    <div class="reveal mt-8 grid max-w-prose gap-4 text-lg text-ink">
      <p>
        Several things are happening at once. The IIA Global Internal Audit Standards took effect in
        January 2025, raising the bar for what an internal audit function is expected to do, and AI
        risk is rising faster than most organisations can govern it.
      </p>
      <p>
        Governance is becoming a board obligation, not a nice to have, as Kenya advances its
        National AI Strategy for 2025 to 2030, enforces the Data Protection Act through the Office
        of the Data Protection Commissioner, and moves an AI Bill forward.
      </p>
      <p>
        At the same time, the established audit-software vendors are repricing and consolidating
        towards large enterprises, which leaves the affordable mid-market lane open. Murikah is
        built for that lane on purpose.
      </p>
    </div>
  </Section>

  {/* How we work. */}
  <Section tone="paper" aria-labelledby="how-we-work">
    <div class="reveal max-w-2xl">
      <p class="eyebrow">How we work</p>
      <h2
        id="how-we-work"
        class="mt-5 font-serif text-[length:var(--text-title)] leading-[1.06] font-semibold tracking-[-0.02em] text-navy"
      >
        Standards in, evidence out
      </h2>
    </div>
    <div class="mt-12 grid gap-x-12 gap-y-10 sm:grid-cols-3">
      {
        how.map((h) => (
          <div class="reveal border-t border-hairline pt-6">
            <h3 class="text-lg text-navy">{h.title}</h3>
            <p class="mt-2.5 text-slate">{h.body}</p>
          </div>
        ))
      }
    </div>
    <div id="standards" class="reveal mt-10">
      <p class="text-xs font-semibold tracking-[0.16em] text-slate uppercase">
        Standards our work follows
      </p>
      <ul class="mt-3 flex flex-wrap gap-2">
        {
          STANDARDS.map((s) => (
            <li class="rounded-full bg-surface px-3 py-1 text-sm text-ink ring-1 ring-hairline">
              {s.name}
            </li>
          ))
        }
      </ul>
    </div>
  </Section>

  {/* What we stand for. */}
  <Section
    id="what-we-stand-for"
    tone="surface"
    aria-labelledby="values"
    class="border-t border-hairline"
  >
    <div class="reveal max-w-2xl">
      <p class="eyebrow">What we stand for</p>
      <h2
        id="values"
        class="mt-5 font-serif text-[length:var(--text-title)] leading-[1.06] font-semibold tracking-[-0.02em] text-navy"
      >
        Three things we will not trade
      </h2>
    </div>
    <div class="mt-12 grid gap-x-12 gap-y-10 sm:grid-cols-3">
      {
        values.map((v) => (
          <div class="reveal border-t border-hairline pt-6">
            <h3 class="text-xl text-navy">{v.title}</h3>
            <p class="mt-2.5 text-slate">{v.body}</p>
          </div>
        ))
      }
    </div>
    <p class="reveal mt-10">
      <Button href="/contact" variant="secondary">Work with us</Button>
    </p>
  </Section>

  <CtaSection
    eyebrow="Book a demo"
    title="Let us raise the standard of your assurance"
    body="Book a demo, or start a conversation about your audit and governance goals."
    secondaryLabel="Contact us"
    secondaryHref="/contact"
  />
</BaseLayout>
