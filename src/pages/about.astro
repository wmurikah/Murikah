---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/primitives/Section.astro';
import Button from '@/components/primitives/Button.astro';
import Card from '@/components/primitives/Card.astro';
import FeatureGrid from '@/components/primitives/FeatureGrid.astro';
import Breadcrumb from '@/components/primitives/Breadcrumb.astro';
import CtaSection from '@/components/primitives/CtaSection.astro';
import { SITE, FOUNDER } from '@/site.config';
import { buildFounderPerson } from '@/lib/schema';

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
];

const values = [
  {
    title: 'Independence',
    body: 'Assurance is only worth what its independence is worth. We protect ours, and yours.',
  },
  {
    title: 'Plain speaking',
    body: 'We write so a board can act on the first read. No jargon for its own sake.',
  },
  {
    title: 'Evidence over assertion',
    body: 'We show the work. Every conclusion is supported by something you can check.',
  },
];

const personSchema = {
  '@context': 'https://schema.org',
  ...buildFounderPerson(),
};
---

<BaseLayout
  titleFull="About Murikah and our founder | Murikah"
  description="Murikah is an AI-native assurance and governance company built in Africa, founded by a CISA and ISO 42001 Lead Auditor who built the platform himself."
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(personSchema)}
    slot="head"
  />

  <Section tone="surface" aria-labelledby="page-title" class="border-b border-hairline">
    <Breadcrumb items={crumbs} class="mb-6" />
    <p class="text-sm font-semibold tracking-widest text-gold uppercase">About</p>
    <h1 id="page-title" class="mt-3 max-w-3xl text-4xl text-balance sm:text-5xl">
      Bringing controls, risks and systems into the light.
    </h1>
    <p class="mt-5 max-w-prose text-lg text-slate">
      {SITE.meaning} Murikah ({SITE.pronunciation}) exists to make controls and risks clear, and to
      help African organisations prove that what they say is happening, really is.
    </p>
  </Section>

  <Section tone="paper" aria-labelledby="what-we-do">
    <div class="grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <h2 id="what-we-do" class="text-2xl sm:text-3xl">What we do</h2>
      </div>
      <div class="lg:col-span-7">
        <p class="max-w-prose text-ink">
          Murikah is an AI-native assurance and governance company, built in Africa. We help
          organisations run, prove and continuously improve their internal audit and their AI and
          system governance, at a fraction of the cost and rigidity of the Big 4 and enterprise
          governance, risk and compliance software.
        </p>
        <p class="mt-4 max-w-prose text-ink">
          We do it across six connected lines, from co-sourced internal audit and the Audit OS
          platform to advisory, training, automation and benchmarking. You can start anywhere and
          grow into the rest, with one team that brings both the judgement and the working software.
        </p>
      </div>
    </div>
  </Section>

  <Section tone="surface" aria-labelledby="why-now">
    <h2 id="why-now" class="text-2xl sm:text-3xl">Why now</h2>
    <div class="mt-6 grid max-w-prose gap-4 text-ink">
      <p>
        Four things are happening at once. The IIA Global Internal Audit Standards took effect in
        January 2025, raising the bar for what an internal audit function is expected to do. AI risk
        is rising faster than most organisations can govern it.
      </p>
      <p>
        Governance is becoming a board obligation, not a nice to have, as Kenya advances its
        National AI Strategy for 2025 to 2030, enforces the Data Protection Act through the Office
        of the Data Protection Commissioner, and moves an AI Bill forward.
      </p>
      <p>
        At the same time, the established audit-software vendors are repricing and consolidating
        towards large enterprises, which leaves the affordable mid-market lane open. Murikah is
        built for that lane on purpose.
      </p>
    </div>
  </Section>

  {/* Founder, the E-E-A-T trust spine. */}
  <Section tone="paper" aria-labelledby="founder">
    <h2 id="founder" class="text-2xl sm:text-3xl">The founder</h2>
    <div class="mt-8 grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <p class="text-xl font-medium text-navy">{FOUNDER.name}</p>
        <p class="text-slate">{FOUNDER.role}</p>
        <p class="mt-5 max-w-prose text-ink">
          {FOUNDER.currentRole} He is a Certified Information Systems Auditor and an ISO 27001 and ISO
          42001 Lead Auditor, the latter still a rare credential for AI management systems. He holds an
          MSc in Information Systems and Technology, is a fellow at an international AI policy institute
          with three peer-reviewed publications, and built the Audit OS platform himself.
        </p>
        <p class="mt-4 max-w-prose text-ink">
          That mix is the point: Murikah ships with the assurance judgement and the working product
          in one person, so the advice and the tool never pull in different directions.
        </p>
      </div>
      <div class="lg:col-span-5">
        <div class="rounded-card bg-surface p-8 ring-1 ring-hairline/70">
          <p class="text-sm font-semibold tracking-widest text-slate uppercase">Credentials</p>
          <ul class="mt-4 grid gap-2.5">
            {
              FOUNDER.credentials.map((c) => (
                <li class="flex items-start gap-2.5">
                  <svg
                    class="mt-1 size-4 shrink-0 text-gold"
                    viewBox="0 0 16 16"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path
                      d="M3 8.5l3 3 7-7.5"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                  <span class="text-ink">{c}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </Section>

  <Section tone="surface" aria-labelledby="values">
    <h2 id="values" class="text-2xl sm:text-3xl">What we stand for</h2>
    <FeatureGrid cols={3} class="mt-8">
      {
        values.map((v) => (
          <Card>
            <h3 class="text-xl text-navy">{v.title}</h3>
            <p class="mt-2 text-slate">{v.body}</p>
          </Card>
        ))
      }
    </FeatureGrid>
    <p class="mt-8">
      <Button href="/contact" variant="secondary">Work with us</Button>
    </p>
  </Section>

  <CtaSection
    title="Let us raise the standard of your assurance"
    body="Book a demo, or start a conversation about your audit and governance goals."
    secondaryLabel="Contact us"
    secondaryHref="/contact"
  />
</BaseLayout>
