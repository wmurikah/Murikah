---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/primitives/Section.astro';
import Prose from '@/components/primitives/Prose.astro';
import Breadcrumb from '@/components/primitives/Breadcrumb.astro';
import { SITE } from '@/site.config';

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Terms', href: '/terms' },
];
---

<BaseLayout
  title="Terms of use"
  description="The terms governing use of the Murikah website."
  noindex={true}
>
  <Section tone="surface" aria-labelledby="page-title">
    <Breadcrumb items={crumbs} class="mb-6" />
    <h1 id="page-title" class="text-4xl sm:text-5xl">Terms of use</h1>
    <p class="mt-3 text-slate">Last updated: [placeholder date]</p>

    <div
      class="mt-6 rounded-card border border-hairline bg-paper p-4 text-sm text-slate"
      role="note"
    >
      <strong class="text-navy">Placeholder:</strong> this is a structural stub, not final legal text.
      Replace with reviewed terms before launch.
    </div>

    <Prose class="mt-10">
      <h2>Acceptance of terms</h2>
      <p>
        By using this website you agree to these terms. If you do not agree, please do not use the
        site. [placeholder]
      </p>

      <h2>Use of the site</h2>
      <p>
        You may use the site for lawful purposes only and must not misuse it or attempt to disrupt
        its operation. [placeholder]
      </p>

      <h2>Intellectual property</h2>
      <p>
        Content on this site is owned by {SITE.legalName} or its licensors and may not be reused without
        permission. [placeholder]
      </p>

      <h2>No warranty</h2>
      <p>
        The site is provided “as is” without warranties of any kind, to the extent permitted by law.
        [placeholder]
      </p>

      <h2>Contact</h2>
      <p>
        Questions about these terms? Contact <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
        [placeholder]
      </p>
    </Prose>
  </Section>
</BaseLayout>
