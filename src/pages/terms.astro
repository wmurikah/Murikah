---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/primitives/Section.astro';
import Prose from '@/components/primitives/Prose.astro';
import Breadcrumb from '@/components/primitives/Breadcrumb.astro';
import { SITE } from '@/site.config';

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Terms', href: '/terms' },
];
---

<BaseLayout
  titleFull="Terms of use | Murikah"
  description="The terms that govern use of the Murikah website, including that the content is general information and not professional advice."
>
  <Section tone="surface" aria-labelledby="page-title">
    <Breadcrumb items={crumbs} class="mb-6" />
    <h1 id="page-title" class="text-4xl sm:text-5xl">Terms of use</h1>
    <p class="mt-3 text-slate">Last updated: {'{{LEGAL: insert date}}'}</p>

    <div
      class="mt-6 rounded-card border border-hairline bg-paper p-4 text-sm text-slate"
      role="note"
    >
      <strong class="text-navy">{'{{LEGAL REVIEW REQUIRED}}'}</strong> This is a plain-English template.
      It must be reviewed and finalised by qualified counsel before launch.
    </div>

    <Prose class="mt-10">
      <h2>Who we are</h2>
      <p>
        This website is operated by Murikah, an assurance and governance company serving
        organisations in Kenya and East Africa. You can reach us at
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
      </p>

      <h2>Using this site</h2>
      <p>
        You may use this site for lawful purposes only. Please do not misuse it, try to disrupt it,
        or attempt to access areas you are not authorised to use.
      </p>

      <h2>Our content is information, not advice</h2>
      <p>
        The guides and pages on this site are general information about assurance, audit, data
        protection and AI governance. They are not legal, audit or professional advice, and you
        should not act on them without advice tailored to your situation. Engaging Murikah for a
        service is the way to get advice you can rely on.
      </p>

      <h2>Intellectual property</h2>
      <p>
        The content on this site, including text, design and the Murikah name and marks, belongs to
        Murikah or its licensors. Please do not reuse it without our written permission.
      </p>

      <h2>Limitation of liability</h2>
      <p>
        We take care to keep the site accurate and available, but we provide it "as is" and cannot
        guarantee it is error-free or always available. To the extent the law allows, we are not
        liable for loss arising from your use of the site. {'{{LEGAL: confirm liability wording}}'}
      </p>

      <h2>Governing law</h2>
      <p>
        These terms are governed by the laws of Kenya, and the courts of Kenya have jurisdiction
        over any dispute.
      </p>

      <h2>Contact</h2>
      <p>
        Questions about these terms? Email <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
      </p>
    </Prose>
  </Section>
</BaseLayout>
