---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/primitives/Section.astro';
import Button from '@/components/primitives/Button.astro';

const quickLinks = [
  { label: 'Services', href: '/assurance' },
  { label: 'Insights', href: '/insights' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];
---

<BaseLayout
  titleFull="Page not found | Murikah"
  description="The page you were looking for could not be found. Find services, insights, about and contact from here."
  noindex={true}
>
  <Section
    tone="navy-rich"
    aria-labelledby="page-title"
    class="relative overflow-hidden text-center"
  >
    <div
      aria-hidden="true"
      class="aperture top-0 left-1/2 h-[26rem] w-[38rem] -translate-x-1/2 -translate-y-1/3"
    >
    </div>
    <div class="relative mx-auto max-w-2xl">
      <p class="eyebrow is-centred">Error 404</p>
      <h1
        id="page-title"
        class="mt-5 font-serif text-[length:var(--text-display)] leading-[1.02] font-semibold tracking-[-0.025em] text-balance text-white"
      >
        We couldn't find that page
      </h1>
      <p class="mx-auto mt-6 max-w-prose text-lg text-paper/80">
        The link may be broken or the page may have moved. Let's get you back on track.
      </p>
      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <Button href="/" variant="primary" size="lg">Back to home</Button>
        <Button
          href="/contact"
          variant="ghost"
          size="lg"
          class="text-white ring-white/25 hover:bg-white/10 hover:ring-white/40"
        >
          Contact us
        </Button>
      </div>
      <ul class="mt-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
        {
          quickLinks.map((l) => (
            <li>
              <a href={l.href} class="font-medium text-paper/75 no-underline hover:text-white">
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </Section>
</BaseLayout>
