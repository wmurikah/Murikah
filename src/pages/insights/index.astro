---
export const prerender = true;

import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/primitives/Section.astro';
import Card from '@/components/primitives/Card.astro';
import FeatureGrid from '@/components/primitives/FeatureGrid.astro';
import Breadcrumb from '@/components/primitives/Breadcrumb.astro';
import CtaSection from '@/components/primitives/CtaSection.astro';
import SubscribeForm from '@/components/SubscribeForm.astro';
import { formatDate, isoDate } from '@/lib/format';

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'News & Insights', href: '/insights' },
  { label: 'All insights', href: '/insights' },
];

const guides = (await getCollection('insights', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

// Category anchor slugs (ai-governance, internal-audit, ...) so the News &
// Insights menu can deep-link to a topic. Each anchor is placed on the first
// guide that carries that category; the grid itself stays dense and ordered by
// date rather than fragmenting into near-empty topic sections.
const categoryAnchor = (cat?: string) =>
  cat
    ? cat
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-|-$/g, '')
    : undefined;

const seen = new Set<string>();
const anchoredGuides = guides.map((g) => {
  const a = categoryAnchor(g.data.category);
  const id = a && !seen.has(a) ? (seen.add(a), a) : undefined;
  return { g, id };
});
---

<BaseLayout
  titleFull="Insights on internal audit, AI governance and data protection | Murikah"
  description="Plain, answer-first guides on internal audit, AI governance, data protection and audit software, written for heads of audit, risk and the board."
>
  <Section
    tone="surface"
    aria-labelledby="page-title"
    class="relative overflow-hidden border-b border-hairline"
  >
    <div aria-hidden="true" class="aperture -top-40 -right-24 h-[30rem] w-[40rem] opacity-50"></div>
    <div class="relative max-w-3xl">
      <Breadcrumb items={crumbs} class="mb-7" />
      <p class="eyebrow">News &amp; Insights</p>
      <h1
        id="page-title"
        class="mt-5 font-serif text-[length:var(--text-title)] leading-[1.05] font-semibold tracking-[-0.02em] text-balance text-navy"
      >
        Guides for assurance, governance and AI
      </h1>
      <p class="mt-6 max-w-2xl text-xl text-slate">
        Practical, answer-first guides for heads of internal audit, risk and the board. Each one
        answers a real question directly, then goes deeper.
      </p>
    </div>
  </Section>

  <Section tone="paper" aria-labelledby="all-guides">
    <h2 id="all-guides" class="sr-only">All guides</h2>
    {
      guides.length === 0 ? (
        <p class="text-slate">No guides published yet. Please check back soon.</p>
      ) : (
        <FeatureGrid cols={3}>
          {anchoredGuides.map(({ g, id }) => (
            <Card id={id} href={`/insights/${g.id}/`} class="flex scroll-mt-28 flex-col">
              {g.data.category && <p class="eyebrow text-xs">{g.data.category}</p>}
              <h3 class="mt-3 text-xl text-navy">{g.data.title}</h3>
              <p class="mt-2 grow text-slate">{g.data.description}</p>
              <p class="mt-4 text-sm text-slate">
                <time datetime={isoDate(g.data.pubDate)}>{formatDate(g.data.pubDate)}</time>
              </p>
            </Card>
          ))}
        </FeatureGrid>
      )
    }

    <p class="mt-10 text-sm text-slate">
      Subscribe via <a href="/rss.xml" class="font-medium text-blue hover:text-blue-deep">RSS</a>.
    </p>
  </Section>

  {
    /* Lead magnet and subscribe anchor. The downloadable asset is a placeholder.
      {{ASSET: final ISO 42001 readiness checklist PDF to add (R2)}} */
  }
  <Section id="subscribe" tone="shade" aria-labelledby="lead-magnet" class="scroll-mt-24">
    <div
      class="grid gap-8 rounded-card bg-surface p-8 ring-1 ring-hairline/70 sm:p-10 md:grid-cols-2 md:items-center"
    >
      <div>
        <h2
          id="lead-magnet"
          class="font-serif text-[length:var(--text-title)] leading-[1.08] font-semibold tracking-[-0.02em] text-navy"
        >
          ISO 42001 readiness checklist
        </h2>
        <p class="mt-3 max-w-prose text-slate">
          A practical, plain-English checklist of the steps an organisation needs to get ready for
          ISO 42001, the management-system standard for governing AI. Tell us where to send it.
        </p>
      </div>
      <SubscribeForm
        source="iso-42001-checklist"
        tone="light"
        buttonLabel="Send me the checklist"
        successMessage="Thank you. We will email the checklist shortly."
        class="md:w-full md:max-w-sm md:justify-self-end"
      />
    </div>
  </Section>

  <CtaSection
    eyebrow="Book a demo"
    title="Bring this rigour to your organisation"
    body="Book a demo to see how Murikah turns guidance into working assurance."
    secondaryLabel="Contact us"
    secondaryHref="/contact"
  />
</BaseLayout>
