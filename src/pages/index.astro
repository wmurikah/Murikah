---
export const prerender = true;

import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/primitives/Container.astro';
import Section from '@/components/primitives/Section.astro';
import Button from '@/components/primitives/Button.astro';
import Card from '@/components/primitives/Card.astro';
import FeatureGrid from '@/components/primitives/FeatureGrid.astro';
import Faq from '@/components/primitives/Faq.astro';
import CtaSection from '@/components/primitives/CtaSection.astro';
import FaqPageSchema from '@/components/schema/FaqPage.astro';
import { SITE, SERVICES, PRIMARY_CTA, AUDIENCE } from '@/site.config';
import type { FaqItem } from '@/lib/types';

const topGuides = (await getCollection('insights', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

// Hero rotating panel: the assurance proof points plus what Labs builds.
const heroSlides = [
  {
    kicker: 'Audit universe',
    title: 'Risks, controls and plans',
    body: 'Organised around how your board thinks.',
  },
  {
    kicker: 'Evidence trail',
    title: 'One system of record',
    body: 'Work papers, reviews and sign-offs kept in one place.',
  },
  {
    kicker: 'Action loop',
    title: 'Findings to closure',
    body: 'From report to owner, deadline, follow-up and closed.',
  },
  {
    kicker: 'Labs',
    title: 'Workflow and process automation',
    body: 'Approvals, reconciliations and reporting across finance and operations.',
  },
  {
    kicker: 'Labs',
    title: 'CRM and CMS builds',
    body: 'Set up, customise and connect the systems that run your work.',
  },
  {
    kicker: 'Labs',
    title: 'Custom internal tools',
    body: 'Internal tools built around how your team actually works.',
  },
  {
    kicker: 'Labs',
    title: 'Data pipelines and reporting',
    body: 'Clean numbers flowing automatically into your dashboards.',
  },
];

const why = [
  {
    title: 'One mental model',
    body: 'The service, system and board reporting share the same structure, reducing handovers and cognitive load.',
  },
];

const faqs: FaqItem[] = [
  {
    question: 'What does Murikah do?',
    answer:
      'Murikah helps African organisations run, prove and improve internal audit and AI governance. We deliver co-sourced and outsourced internal audit, Audit OS, advisory, training and automation builds in one joined-up relationship.',
  },
  {
    question: 'Who is Murikah for?',
    answer:
      'Heads of internal audit, audit committee and board chairs, CFOs, CEOs, and heads of risk and compliance at regulated mid-market organisations. Our first focus is SACCOs, banks, microfinance institutions, fintechs, donor-funded NGOs and family businesses with active boards.',
  },
  {
    question: 'How is Murikah different from the Big 4 and from audit software?',
    answer:
      'We combine senior assurance judgement and the platform it runs on. You get people who can reason through the work, software that keeps evidence and follow-up moving, and a cost model designed for the African mid-market.',
  },
];
---

<BaseLayout
  titleFull="Internal audit and AI governance, built in Africa | Murikah"
  description={SITE.description}
>
  <section class="hero-luxe on-dark relative overflow-hidden" aria-labelledby="hero-title">
    <div aria-hidden="true" class="orb orb-one"></div>
    <div aria-hidden="true" class="orb orb-two"></div>
    <Container class="relative py-12 sm:py-16 lg:py-20">
      <div class="grid items-center gap-10 lg:grid-cols-[1.02fr_0.98fr] lg:gap-16">
        <div>
          <p class="eyebrow rise" style="--rise-delay: 0.05s">
            AI-native assurance for boards that need proof
          </p>
          <h1
            id="hero-title"
            class="rise mt-6 max-w-3xl text-[length:var(--text-display)] leading-[1.07] font-semibold tracking-[-0.02em] text-balance text-white"
            style="--rise-delay: 0.13s"
          >
            Make assurance feel inevitable.
          </h1>
          <p class="rise mt-5 max-w-xl text-lg leading-7 text-white/72" style="--rise-delay: 0.22s">
            Murikah gives African organisations a calm way to run internal audit, govern AI, prove
            the evidence and keep remediation moving. Senior judgement and Audit OS work as one
            operating layer.
          </p>
          <div class="rise mt-8 flex flex-col gap-3 sm:flex-row" style="--rise-delay: 0.31s">
            <Button href={PRIMARY_CTA.href} variant="primary" size="lg">{PRIMARY_CTA.label}</Button>
            <Button
              href="/audit-os"
              variant="ghost"
              size="lg"
              class="text-white ring-white/20 hover:bg-white/10 hover:ring-white/40"
            >
              Explore Audit OS
            </Button>
          </div>
        </div>

        <div class="rise hero-device" style="--rise-delay: 0.38s" aria-label="Audit OS preview">
          <div class="device-topbar">
            <span></span><span></span><span></span>
          </div>
          <div class="device-screen">
            <div class="device-header">
              <div>
                <p class="text-xs font-semibold tracking-[0.18em] text-gold uppercase">
                  Live assurance
                </p>
                <h2 class="mt-2 text-xl text-white">What we run</h2>
              </div>
              <div
                class="rounded-full bg-emerald-400/12 px-3 py-1 text-sm text-emerald-100 ring-1 ring-emerald-300/20"
              >
                On track
              </div>
            </div>
            <div class="hero-slides mt-6" data-hero-slides>
              {
                heroSlides.map((s, i) => (
                  <article
                    class:list={['hero-slide', i === 0 && 'is-active']}
                    data-hero-slide
                    aria-hidden={i === 0 ? 'false' : 'true'}
                  >
                    <p class="text-xs font-semibold tracking-[0.16em] text-gold uppercase">
                      {s.kicker}
                    </p>
                    <h3 class="mt-3 text-xl text-white">{s.title}</h3>
                    <p class="mt-2 text-sm text-white/62">{s.body}</p>
                  </article>
                ))
              }
            </div>
            <div class="mt-5 flex justify-center gap-2" aria-hidden="true">
              {
                heroSlides.map((_, i) => (
                  <span class:list={['hero-dot', i === 0 && 'is-active']} data-hero-dot />
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <Section tone="surface" aria-labelledby="services-title" class="border-b border-hairline">
    <div class="reveal mx-auto max-w-3xl text-center">
      <p class="eyebrow is-centred">What we do</p>
      <h2
        id="services-title"
        class="mt-5 text-[length:var(--text-title)] leading-[1.1] font-semibold tracking-[-0.015em] text-navy"
      >
        Six connected services. One clear system.
      </h2>
      <p class="mt-5 text-lg text-slate">
        We use progressive disclosure: start with the urgent need, then expand into the connected
        capability when your team is ready.
      </p>
    </div>

    <div class="mt-14 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        SERVICES.map((s, i) => (
          <a href={s.href} class="reveal group premium-card no-underline">
            <span class="text-sm font-semibold tracking-[0.16em] text-gold uppercase">
              {String(i + 1).padStart(2, '0')}
            </span>
            <h3 class="mt-6 text-2xl text-navy">{s.fullName}</h3>
            <p class="mt-3 text-slate">{s.summary}</p>
            <span class="mt-auto inline-flex items-center gap-2 pt-6 font-medium text-blue">
              View service{' '}
              <span class="transition-transform group-hover:translate-x-1">&rarr;</span>
            </span>
          </a>
        ))
      }
    </div>
  </Section>

  <Section tone="paper" aria-labelledby="experience-title">
    <div class="grid items-start gap-12 lg:grid-cols-12 lg:gap-16">
      <div class="reveal lg:sticky lg:top-28 lg:col-span-5">
        <p class="eyebrow">Experience principles</p>
        <h2
          id="experience-title"
          class="mt-5 text-[length:var(--text-title)] leading-[1.1] font-semibold tracking-[-0.015em] text-navy"
        >
          Built to reduce friction, not add another system to babysit.
        </h2>
      </div>
      <div class="lg:col-span-7">
        {
          why.map((w) => (
            <div class="reveal border-t border-hairline py-8 first:border-t-0 first:pt-0">
              <h3 class="text-2xl text-navy">{w.title}</h3>
              <p class="mt-3 max-w-2xl text-lg text-slate">{w.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </Section>

  <Section tone="surface" aria-labelledby="audience-title" class="border-y border-hairline">
    <div class="reveal mx-auto max-w-3xl text-center">
      <p class="eyebrow is-centred">Who it is for</p>
      <h2
        id="audience-title"
        class="mt-5 text-[length:var(--text-title)] leading-[1.1] font-semibold tracking-[-0.015em] text-navy"
      >
        For teams accountable to boards, regulators and funders.
      </h2>
    </div>
    <div class="mt-12 grid gap-4 md:grid-cols-2 lg:grid-cols-5">
      {
        AUDIENCE.map((seg) => (
          <div class="reveal rounded-[1.6rem] bg-paper p-6 ring-1 ring-hairline">
            <p class="font-medium text-navy">{seg.name}</p>
            <p class="mt-2 text-sm text-slate">{seg.note}</p>
          </div>
        ))
      }
    </div>
  </Section>

  {
    topGuides.length > 0 && (
      <Section tone="paper" aria-labelledby="guides-title">
        <div class="reveal flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="eyebrow">Insights</p>
            <h2
              id="guides-title"
              class="mt-5 text-[length:var(--text-title)] leading-[1.1] font-semibold tracking-[-0.015em] text-navy"
            >
              Learn the thinking behind the system
            </h2>
          </div>
          <a
            href="/insights"
            class="font-medium text-blue no-underline hover:text-blue-deep hover:underline"
          >
            All insights &rarr;
          </a>
        </div>
        <FeatureGrid cols={3} class="mt-12">
          {topGuides.map((g) => (
            <Card href={`/insights/${g.id}/`} class="reveal flex flex-col">
              {g.data.category && <p class="eyebrow text-xs">{g.data.category}</p>}
              <h3 class="mt-3 text-lg text-navy">{g.data.title}</h3>
              <p class="mt-2 grow text-slate">{g.data.description}</p>
              <span
                aria-hidden="true"
                class="mt-5 inline-flex items-center gap-1 text-sm font-medium text-blue"
              >
                Read guide <span>&rarr;</span>
              </span>
            </Card>
          ))}
        </FeatureGrid>
      </Section>
    )
  }

  <Section tone="surface" aria-labelledby="home-faq" class="border-t border-hairline">
    <div class="reveal max-w-2xl">
      <p class="eyebrow">Questions</p>
      <h2
        id="home-faq"
        class="mt-5 text-[length:var(--text-title)] leading-[1.1] font-semibold tracking-[-0.015em] text-navy"
      >
        Questions before you book
      </h2>
    </div>
    <Faq items={faqs} class="reveal mt-10 max-w-3xl" />
    <FaqPageSchema items={faqs} />
  </Section>

  <CtaSection
    eyebrow="Book a demo"
    title="See assurance designed like a product, not a pile of files"
    body="Book a demo and we will map Murikah to your audit universe, your regulator and your board."
    secondaryLabel="Contact us"
    secondaryHref="/contact"
  />

  <script>
    // Hero rotating panel: cross-fade the slides on a timer. The first slide is
    // active in the markup, so without JS it shows statically. Auto-rotation is
    // skipped when the visitor prefers reduced motion.
    function initHeroSlides() {
      const root = document.querySelector('[data-hero-slides]');
      if (!root) return;
      const slides = Array.from(root.querySelectorAll<HTMLElement>('[data-hero-slide]'));
      const dots = Array.from(document.querySelectorAll<HTMLElement>('[data-hero-dot]'));
      if (slides.length < 2) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      let i = 0;
      setInterval(() => {
        slides[i].classList.remove('is-active');
        slides[i].setAttribute('aria-hidden', 'true');
        dots[i]?.classList.remove('is-active');
        i = (i + 1) % slides.length;
        slides[i].classList.add('is-active');
        slides[i].setAttribute('aria-hidden', 'false');
        dots[i]?.classList.add('is-active');
      }, 4000);
    }
    initHeroSlides();
  </script>
</BaseLayout>
