---
export const prerender = true;

import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/primitives/Container.astro';
import Section from '@/components/primitives/Section.astro';
import Button from '@/components/primitives/Button.astro';
import Card from '@/components/primitives/Card.astro';
import FeatureGrid from '@/components/primitives/FeatureGrid.astro';
import Faq from '@/components/primitives/Faq.astro';
import CtaSection from '@/components/primitives/CtaSection.astro';
import FaqPageSchema from '@/components/schema/FaqPage.astro';
import HeroMotionPanel from '@/components/hero/HeroMotionPanel';
import { SITE, SERVICES, PRIMARY_CTA, AUDIENCE } from '@/site.config';
import type { FaqItem } from '@/lib/types';

const topGuides = (await getCollection('insights', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const why = [
  {
    title: 'Nothing gets lost in the handover',
    body: 'The service, the platform and your board reporting share one structure, so evidence carries straight from fieldwork to the board pack without being rebuilt at each step.',
  },
];

const faqs: FaqItem[] = [
  {
    question: 'What does Murikah do?',
    answer:
      'Murikah helps organisations run, prove and improve internal audit and AI governance. We deliver co-sourced and outsourced internal audit, Assurance OS, advisory, training and automation builds in one joined-up relationship.',
  },
  {
    question: 'Who is Murikah for?',
    answer:
      'Heads of internal audit, audit committee and board chairs, CFOs, CEOs, and heads of risk and compliance at regulated mid-market organisations. Our first focus is SACCOs, banks, microfinance institutions, fintechs, donor-funded NGOs and family businesses with active boards.',
  },
  {
    question: 'How is Murikah different from the Big 4 and from audit software?',
    answer:
      'We combine senior assurance judgement and the platform it runs on. You get people who can reason through the work, software that keeps evidence and follow-up moving, and a cost model designed for the mid-market.',
  },
];
---

<BaseLayout titleFull="Internal audit and AI governance | Murikah" description={SITE.description}>
  <section class="navy-rich grain on-dark relative overflow-hidden" aria-labelledby="hero-title">
    {/* One restrained brass bloom behind the headline for cinematic depth. */}
    <div
      aria-hidden="true"
      class="aperture top-[-8rem] left-[-6rem] h-[32rem] w-[38rem] opacity-70"
    >
    </div>
    <Container class="relative">
      {
        /* Split hero: copy left, cinematic motion panel right. The grid fills the
          first screen on desktop (clamped so it is never cramped on small
          laptops nor blank on very large screens) and stacks with the copy
          first on mobile. */
      }
      <div
        class="grid items-center gap-10 py-12 sm:py-16 lg:min-h-[clamp(40rem,calc(100svh-var(--header-height)),52rem)] lg:grid-cols-[minmax(0,1fr)_minmax(0,1.02fr)] lg:items-stretch lg:gap-14 lg:py-0"
      >
        <div class="flex flex-col justify-center lg:py-16">
          <p class="eyebrow rise" style="--rise-delay: 0.05s">
            AI-native assurance for boards that need proof
          </p>
          <h1
            id="hero-title"
            class="rise mt-6 max-w-[18ch] text-[length:var(--text-display)] leading-[1.07] font-semibold tracking-[-0.02em] text-balance text-white"
            style="--rise-delay: 0.13s"
          >
            Make assurance feel inevitable.
          </h1>
          <p class="rise mt-5 max-w-xl text-lg leading-7 text-paper/80" style="--rise-delay: 0.22s">
            Murikah helps organisations govern risk, prove evidence, strengthen systems and turn
            assurance into a calm operating rhythm.
          </p>
          <div class="rise mt-8 flex flex-col gap-3 sm:flex-row" style="--rise-delay: 0.3s">
            <Button href={PRIMARY_CTA.href} variant="primary" size="lg">{PRIMARY_CTA.label}</Button>
            <Button href="/audit-os" variant="ghost" size="lg">Explore Assurance OS</Button>
          </div>
          <p class="rise mt-7 max-w-md text-sm text-paper/60" style="--rise-delay: 0.37s">
            Advisory, analytics and Assurance OS work as one operating layer.
          </p>
        </div>

        <div class="rise w-full self-stretch lg:py-14" style="--rise-delay: 0.42s">
          <HeroMotionPanel client:visible />
        </div>
      </div>
    </Container>
  </section>

  <Section tone="surface" aria-labelledby="services-title" class="border-b border-hairline">
    <div class="reveal mx-auto max-w-3xl text-center">
      <p class="eyebrow is-centred">What we do</p>
      <h2
        id="services-title"
        class="mt-5 text-[length:var(--text-title)] leading-[1.1] font-semibold tracking-[-0.015em] text-navy"
      >
        Six connected services. One clear system.
      </h2>
      <p class="mt-5 text-lg text-slate">
        Start with what is most urgent. The rest of the system is ready when your team is, not
        before, so you are never paying for capability you have not grown into yet.
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        SERVICES.map((s, i) => (
          <a href={s.href} class="reveal group premium-card no-underline">
            <span class="text-sm font-semibold tracking-[0.16em] text-gold uppercase">
              {String(i + 1).padStart(2, '0')}
            </span>
            <h3 class="mt-6 text-2xl text-navy">{s.fullName}</h3>
            <p class="mt-3 text-slate">{s.summary}</p>
            <span class="mt-auto inline-flex items-center gap-2 pt-6 font-medium text-blue">
              View service{' '}
              <span class="transition-transform group-hover:translate-x-1">&rarr;</span>
            </span>
          </a>
        ))
      }
    </div>
  </Section>

  <Section tone="paper" aria-labelledby="experience-title">
    <div class="grid items-start gap-12 lg:grid-cols-12 lg:gap-16">
      <div class="reveal lg:sticky lg:top-28 lg:col-span-5">
        <p class="eyebrow">Why it works</p>
        <h2
          id="experience-title"
          class="mt-5 text-[length:var(--text-title)] leading-[1.1] font-semibold tracking-[-0.015em] text-navy"
        >
          Built to fit your team, not to become another system to babysit.
        </h2>
      </div>
      <div class="lg:col-span-7">
        {
          why.map((w) => (
            <div class="reveal border-t border-hairline py-8 first:border-t-0 first:pt-0">
              <h3 class="text-2xl text-navy">{w.title}</h3>
              <p class="mt-3 max-w-2xl text-lg text-slate">{w.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </Section>

  <Section tone="surface" aria-labelledby="audience-title" class="border-y border-hairline">
    <div class="reveal mx-auto max-w-3xl text-center">
      <p class="eyebrow is-centred">Who it is for</p>
      <h2
        id="audience-title"
        class="mt-5 text-[length:var(--text-title)] leading-[1.1] font-semibold tracking-[-0.015em] text-navy"
      >
        For teams accountable to boards, regulators and funders.
      </h2>
    </div>
    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-5">
      {
        AUDIENCE.map((seg) => (
          <div class="reveal rounded-[1.6rem] bg-paper p-6 ring-1 ring-hairline">
            <p class="font-medium text-navy">{seg.name}</p>
            <p class="mt-2 text-sm text-slate">{seg.note}</p>
          </div>
        ))
      }
    </div>
  </Section>

  {
    topGuides.length > 0 && (
      <Section tone="paper" aria-labelledby="guides-title">
        <div class="reveal flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="eyebrow">Insights</p>
            <h2
              id="guides-title"
              class="mt-5 text-[length:var(--text-title)] leading-[1.1] font-semibold tracking-[-0.015em] text-navy"
            >
              Learn the thinking behind the system
            </h2>
          </div>
          <a
            href="/insights"
            class="font-medium text-blue no-underline hover:text-blue-deep hover:underline"
          >
            All insights &rarr;
          </a>
        </div>
        <FeatureGrid cols={3} class="mt-12">
          {topGuides.map((g) => (
            <Card href={`/insights/${g.id}/`} class="reveal flex flex-col">
              {g.data.category && <p class="eyebrow text-xs">{g.data.category}</p>}
              <h3 class="mt-3 text-lg text-navy">{g.data.title}</h3>
              <p class="mt-2 grow text-slate">{g.data.description}</p>
              <span
                aria-hidden="true"
                class="mt-5 inline-flex items-center gap-1 text-sm font-medium text-blue"
              >
                Read guide <span>&rarr;</span>
              </span>
            </Card>
          ))}
        </FeatureGrid>
      </Section>
    )
  }

  <Section tone="surface" aria-labelledby="home-faq" class="border-t border-hairline">
    <div class="reveal max-w-2xl">
      <p class="eyebrow">Questions</p>
      <h2
        id="home-faq"
        class="mt-5 text-[length:var(--text-title)] leading-[1.1] font-semibold tracking-[-0.015em] text-navy"
      >
        Questions before you book
      </h2>
    </div>
    <Faq items={faqs} class="reveal mt-10 max-w-3xl" />
    <FaqPageSchema items={faqs} />
  </Section>

  <CtaSection
    eyebrow="Book a demo"
    title="See assurance designed like a product, not a pile of files"
    body="Book a demo and we will map Murikah to your audit universe, your regulator and your board."
    secondaryLabel="Contact us"
    secondaryHref="/contact"
  />
</BaseLayout>
