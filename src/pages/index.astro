---
export const prerender = true;

import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/primitives/Container.astro';
import Section from '@/components/primitives/Section.astro';
import Button from '@/components/primitives/Button.astro';
import Card from '@/components/primitives/Card.astro';
import FeatureGrid from '@/components/primitives/FeatureGrid.astro';
import Faq from '@/components/primitives/Faq.astro';
import CtaSection from '@/components/primitives/CtaSection.astro';
import FaqPageSchema from '@/components/schema/FaqPage.astro';
import { SITE, SERVICES, PRIMARY_CTA, AUDIENCE } from '@/site.config';
import type { FaqItem } from '@/lib/types';

// Top three guides, newest first, for the home hub-and-spoke links.
const topGuides = (await getCollection('insights', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const why = [
  {
    title: 'Service and software in one house',
    body: 'The audit and the platform it runs on come from the same team, so nothing falls between a consultant and a vendor.',
  },
  {
    title: 'Standards-based and AI-native',
    body: 'Our assurance work follows the IIA Global Internal Audit Standards, with AI governance built in from the start under ISO 42001, not added on later.',
  },
  {
    title: 'Built for the African mid-market',
    body: 'Designed for SACCOs, banks, fintechs and NGOs here, not a global enterprise template forced to fit.',
  },
  {
    title: 'Senior judgement, fair pricing',
    body: 'Board-ready work without Big-4 fees or enterprise GRC licences, and you keep the evidence and the system when we step back.',
  },
];

const faqs: FaqItem[] = [
  {
    question: 'What does Murikah do?',
    answer:
      'Murikah helps African organisations run, prove and improve their internal audit and AI governance. We deliver co-sourced and outsourced internal audit, a platform called Audit OS to run it on, advisory and training, and automation builds through Murikah Labs. You get senior judgement and working software in one relationship, priced for the mid-market.',
  },
  {
    question: 'Who is Murikah for?',
    answer:
      'Heads of internal audit, audit committee and board chairs, CFOs, CEOs, and heads of risk and compliance at regulated mid-market organisations. Our first focus is SACCOs, banks, microfinance institutions and fintechs, and donor-funded NGOs, with family businesses that have active boards close behind.',
  },
  {
    question: 'How is Murikah different from the Big 4 and from audit software?',
    answer:
      'We combine both in one house. The Big 4 bring people but bill heavily and leave little behind. Audit software gives you a tool but no judgement. Murikah gives you senior, standards-based assurance and the platform it runs on, priced for the African mid-market, and you keep the evidence and the system when we step back.',
  },
];
---

<BaseLayout
  titleFull="Internal audit and AI governance, built in Africa | Murikah"
  description={SITE.description}
>
  {
    /* Hero: the signature moment. Rich navy, one soft aperture of light behind a
      confident Fraunces headline, with a staggered load sequence. */
  }
  <section class="navy-rich grain on-dark relative overflow-hidden" aria-labelledby="hero-title">
    <div
      aria-hidden="true"
      class="aperture top-[14%] left-[6%] h-[32rem] w-[44rem] opacity-90 sm:h-[40rem] sm:w-[56rem]"
    >
    </div>
    <Container class="relative">
      <div class="max-w-3xl py-24 sm:py-28 lg:py-36">
        <p class="eyebrow rise" style="--rise-delay: 0.05s">
          AI-native assurance and governance, built in Africa
        </p>
        <h1
          id="hero-title"
          class="rise mt-6 font-serif text-[length:var(--text-display)] leading-[1.02] font-semibold tracking-[-0.028em] text-pretty break-words text-white"
          style="--rise-delay: 0.13s"
        >
          Assurance you can run, prove, and keep improving.
        </h1>
        <p class="rise mt-7 max-w-2xl text-lg text-paper/80 sm:text-xl" style="--rise-delay: 0.22s">
          Murikah helps African organisations run their internal audit and AI governance, prove it
          to boards and regulators, and improve it continuously. Senior judgement and a working
          platform in one relationship, priced for the mid-market, not the global enterprise.
        </p>
        <div class="rise mt-10 flex flex-col gap-3 sm:flex-row" style="--rise-delay: 0.31s">
          <Button href={PRIMARY_CTA.href} variant="primary" size="lg">{PRIMARY_CTA.label}</Button>
          <Button
            href="/audit-os"
            variant="ghost"
            size="lg"
            class="text-white ring-white/25 hover:bg-white/10 hover:ring-white/40"
          >
            Explore Audit OS
          </Button>
        </div>
        <div class="rise mt-14 max-w-xl" style="--rise-delay: 0.4s">
          <hr class="beam border-0" />
          <p class="mt-4 text-sm text-paper/60">
            Our work follows the IIA Global Internal Audit Standards, ISO/IEC 27001 and ISO/IEC
            42001.
          </p>
        </div>
      </div>
    </Container>
  </section>

  {/* Six lines, as an editorial index rather than a card grid. */}
  <Section tone="paper" aria-labelledby="services-title">
    <div class="reveal max-w-2xl">
      <p class="eyebrow">What we do</p>
      <h2
        id="services-title"
        class="mt-5 font-serif text-[length:var(--text-title)] leading-[1.06] font-semibold tracking-[-0.02em] text-navy"
      >
        One company, six ways we help
      </h2>
      <p class="mt-4 text-lg text-slate">
        From the audit itself to the platform it runs on, each line stands alone or works with the
        others.
      </p>
    </div>

    <ul class="mt-14 border-t border-hairline">
      {
        SERVICES.map((s, i) => (
          <li class="reveal">
            <a
              href={s.href}
              class="group grid grid-cols-[2.5rem_1fr] items-baseline gap-x-5 gap-y-2 border-b border-hairline py-7 no-underline transition-[padding] duration-200 ease-[cubic-bezier(0.22,1,0.36,1)] hover:pl-2 sm:grid-cols-[3rem_1fr_auto] sm:py-8"
            >
              <span class="font-serif text-xl text-gold tabular-nums sm:text-2xl">
                {String(i + 1).padStart(2, '0')}
              </span>
              <div>
                <h3 class="text-xl text-navy transition-colors group-hover:text-blue sm:text-2xl">
                  {s.fullName}
                </h3>
                <p class="mt-2 max-w-2xl text-slate">{s.summary}</p>
              </div>
              <span
                aria-hidden="true"
                class="col-start-2 mt-1 inline-flex items-center gap-1 font-medium text-blue sm:col-start-3 sm:mt-0 sm:self-center"
              >
                <span class="hidden sm:inline">View</span>
                <span class="transition-transform duration-200 group-hover:translate-x-1">
                  &rarr;
                </span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </Section>

  {/* Who it is for, asymmetric: a statement beside a quiet list. */}
  <Section tone="surface" aria-labelledby="audience-title" class="border-y border-hairline">
    <div class="grid gap-10 lg:grid-cols-12 lg:gap-16">
      <div class="reveal lg:col-span-5">
        <p class="eyebrow">Who it is for</p>
        <h2
          id="audience-title"
          class="mt-5 font-serif text-[length:var(--text-title)] leading-[1.06] font-semibold tracking-[-0.02em] text-navy"
        >
          Built for the people accountable for assurance
        </h2>
        <p class="mt-4 text-lg text-slate">
          Regulated, mid-market organisations and the boards, audit committees and executives who
          answer for their controls and their risk.
        </p>
      </div>
      <ul class="reveal lg:col-span-7">
        {
          AUDIENCE.map((seg) => (
            <li class="border-t border-hairline py-5 first:border-t-0 lg:py-6">
              <p class="font-medium text-navy">{seg.name}</p>
              <p class="mt-1.5 text-slate">{seg.note}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </Section>

  {/* Why Murikah, depersonalised: company-level reasons, not credentials. */}
  <Section tone="paper" aria-labelledby="why-title">
    <div class="reveal max-w-2xl">
      <p class="eyebrow">Why Murikah</p>
      <h2
        id="why-title"
        class="mt-5 font-serif text-[length:var(--text-title)] leading-[1.06] font-semibold tracking-[-0.02em] text-navy"
      >
        The service and the software, from one team
      </h2>
    </div>
    <div class="mt-12 grid gap-x-12 gap-y-10 sm:grid-cols-2">
      {
        why.map((w) => (
          <div class="reveal border-t border-hairline pt-6">
            <h3 class="text-xl text-navy">{w.title}</h3>
            <p class="mt-2.5 text-slate">{w.body}</p>
          </div>
        ))
      }
    </div>
  </Section>

  {/* Top guides (hub-and-spoke). */}
  {
    topGuides.length > 0 && (
      <Section tone="surface" aria-labelledby="guides-title" class="border-t border-hairline">
        <div class="reveal flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="eyebrow">Insights</p>
            <h2
              id="guides-title"
              class="mt-5 font-serif text-[length:var(--text-title)] leading-[1.06] font-semibold tracking-[-0.02em] text-navy"
            >
              Start with a guide
            </h2>
          </div>
          <a
            href="/insights"
            class="font-medium text-blue no-underline hover:text-blue-deep hover:underline"
          >
            All insights &rarr;
          </a>
        </div>
        <FeatureGrid cols={3} class="mt-12">
          {topGuides.map((g) => (
            <Card href={`/insights/${g.id}/`} class="reveal flex flex-col">
              {g.data.category && <p class="eyebrow text-xs">{g.data.category}</p>}
              <h3 class="mt-3 text-lg text-navy">{g.data.title}</h3>
              <p class="mt-2 grow text-slate">{g.data.description}</p>
              <span
                aria-hidden="true"
                class="mt-5 inline-flex items-center gap-1 text-sm font-medium text-blue"
              >
                Read guide <span>&rarr;</span>
              </span>
            </Card>
          ))}
        </FeatureGrid>
      </Section>
    )
  }

  {/* Home FAQ + matching schema. */}
  <Section tone="paper" aria-labelledby="home-faq">
    <div class="reveal max-w-2xl">
      <p class="eyebrow">Questions</p>
      <h2
        id="home-faq"
        class="mt-5 font-serif text-[length:var(--text-title)] leading-[1.06] font-semibold tracking-[-0.02em] text-navy"
      >
        Common questions
      </h2>
    </div>
    <Faq items={faqs} class="reveal mt-10 max-w-3xl" />
    <FaqPageSchema items={faqs} />
  </Section>

  <CtaSection
    eyebrow="Book a demo"
    title="See what assurance looks like when it is built to be proven"
    body="Book a demo and we will map Murikah to your audit universe, your regulator and your board."
    secondaryLabel="Contact us"
    secondaryHref="/contact"
  />
</BaseLayout>
