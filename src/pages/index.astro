---
export const prerender = true;

import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/primitives/Container.astro';
import Section from '@/components/primitives/Section.astro';
import Button from '@/components/primitives/Button.astro';
import Card from '@/components/primitives/Card.astro';
import FeatureGrid from '@/components/primitives/FeatureGrid.astro';
import Faq from '@/components/primitives/Faq.astro';
import CtaSection from '@/components/primitives/CtaSection.astro';
import FaqPageSchema from '@/components/schema/FaqPage.astro';
import { SITE, SERVICES, PRIMARY_CTA, AUDIENCE } from '@/site.config';
import type { FaqItem } from '@/lib/types';

const topGuides = (await getCollection('insights', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const commandMetrics = [
  { label: 'Audit plan', value: 'Risk-led' },
  { label: 'Evidence', value: 'Signed off' },
  { label: 'Actions', value: 'Tracked' },
  { label: 'Board pack', value: 'Ready' },
];

const proofPoints = [
  {
    step: '01',
    title: 'Plan with clarity',
    body: 'Map risks, controls, owners and engagements before fieldwork starts.',
  },
  {
    step: '02',
    title: 'Collect evidence once',
    body: 'Keep work papers, review notes and sign-offs in a single audit trail.',
  },
  {
    step: '03',
    title: 'Close the loop',
    body: 'Turn findings into owners, deadlines, follow-up and board-visible status.',
  },
];

const bento = [
  {
    title: 'Assurance that reads like a product',
    body: 'Clear screens, plain language and deliberate hierarchy so executives understand what matters without decoding audit jargon.',
  },
  {
    title: 'AI governance without theatre',
    body: 'ISO/IEC 42001 readiness, data protection awareness and pragmatic controls that teams can actually run.',
  },
  {
    title: 'A system your team keeps',
    body: 'The platform, evidence, finding history and reporting discipline remain useful after the engagement.',
  },
];

const faqs: FaqItem[] = [
  {
    question: 'What does Murikah do?',
    answer:
      'Murikah helps African organisations run, prove and improve internal audit and AI governance. We deliver co-sourced and outsourced internal audit, Audit OS, advisory, training and automation builds in one joined-up relationship.',
  },
  {
    question: 'Who is Murikah for?',
    answer:
      'Heads of internal audit, audit committee and board chairs, CFOs, CEOs, and heads of risk and compliance at regulated mid-market organisations. Our first focus is SACCOs, banks, microfinance institutions, fintechs, donor-funded NGOs and family businesses with active boards.',
  },
  {
    question: 'How is Murikah different from the Big 4 and from audit software?',
    answer:
      'We combine senior assurance judgement and the platform it runs on. You get people who can reason through the work, software that keeps evidence and follow-up moving, and a cost model designed for the African mid-market.',
  },
];
---

<BaseLayout
  titleFull="Internal audit and AI governance, built in Africa | Murikah"
  description={SITE.description}
>
  <section class="showpiece relative overflow-hidden" aria-labelledby="hero-title">
    <div aria-hidden="true" class="showpiece-grid"></div>
    <div aria-hidden="true" class="showpiece-glow showpiece-glow-a"></div>
    <div aria-hidden="true" class="showpiece-glow showpiece-glow-b"></div>
    <Container class="relative py-14 sm:py-16 lg:py-20">
      <div class="mx-auto max-w-5xl text-center">
        <p class="eyebrow rise is-centred" style="--rise-delay: 0.05s">
          Assurance, governance and evidence in one calm operating system
        </p>
        <h1
          id="hero-title"
          class="rise mx-auto mt-5 max-w-4xl text-[clamp(2.75rem,7vw,5.8rem)] leading-[0.9] font-semibold tracking-[-0.06em] text-balance text-white"
          style="--rise-delay: 0.13s"
        >
          The board can see it. The team can run it.
        </h1>
        <p
          class="rise mx-auto mt-6 max-w-2xl text-base leading-7 text-white/70 sm:text-xl sm:leading-8"
          style="--rise-delay: 0.22s"
        >
          Murikah turns internal audit and AI governance into a premium, evidence-led experience:
          senior judgement, Audit OS and board-ready reporting built for African organisations.
        </p>
        <div
          class="rise mt-8 flex flex-col justify-center gap-3 sm:flex-row"
          style="--rise-delay: 0.31s"
        >
          <Button href={PRIMARY_CTA.href} variant="primary" size="lg">{PRIMARY_CTA.label}</Button>
          <Button
            href="/audit-os"
            variant="ghost"
            size="lg"
            class="text-white ring-white/25 hover:bg-white/10 hover:ring-white/45"
          >
            See Audit OS
          </Button>
        </div>
      </div>

      <div class="rise mt-10" style="--rise-delay: 0.4s">
        <div class="command-shell mx-auto max-w-6xl">
          <div class="command-rail">
            <span></span><span></span><span></span>
          </div>
          <div class="command-screen">
            <div class="grid gap-5 lg:grid-cols-[0.9fr_1.1fr]">
              <div class="command-panel command-panel-dark">
                <p class="text-xs font-semibold tracking-[0.18em] text-gold uppercase">
                  Murikah command
                </p>
                <h2 class="mt-3 text-2xl leading-tight tracking-[-0.035em] text-white sm:text-3xl">
                  Assurance status, without the scramble.
                </h2>
                <p class="mt-4 text-white/58">
                  A single view of scope, evidence, actions and board readiness.
                </p>
                <div class="mt-5 grid grid-cols-2 gap-2">
                  {
                    commandMetrics.map((metric) => (
                      <div class="rounded-xl bg-white/[0.07] p-3 ring-1 ring-white/10">
                        <p class="text-xs text-white/45">{metric.label}</p>
                        <p class="mt-1 text-lg font-medium text-white">{metric.value}</p>
                      </div>
                    ))
                  }
                </div>
              </div>
              <div class="grid gap-3">
                {
                  proofPoints.map((item) => (
                    <div class="command-row">
                      <span>{item.step}</span>
                      <div>
                        <h3>{item.title}</h3>
                        <p>{item.body}</p>
                      </div>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <Section
    tone="paper"
    aria-labelledby="position-title"
    class="border-b border-hairline !py-12 lg:!py-16"
  >
    <div class="reveal mx-auto max-w-4xl text-center">
      <p class="eyebrow is-centred">The new standard</p>
      <h2
        id="position-title"
        class="mt-5 text-[clamp(2rem,5vw,4.25rem)] leading-[0.96] font-semibold tracking-[-0.055em] text-balance text-navy"
      >
        Not another consultancy deck. Not another abandoned tool.
      </h2>
      <p class="mx-auto mt-7 max-w-2xl text-xl text-slate">
        The service, software and reporting model are designed together, so assurance feels coherent
        from fieldwork to committee pack.
      </p>
    </div>
    <div class="mt-10 grid gap-4 lg:grid-cols-3">
      {
        bento.map((item, index) => (
          <article class:list={['reveal bento-card', index === 0 && 'lg:row-span-2']}>
            <p class="text-sm font-semibold tracking-[0.16em] text-gold uppercase">0{index + 1}</p>
            <h3 class="mt-5 text-2xl leading-tight tracking-[-0.035em] text-navy">{item.title}</h3>
            <p class="mt-4 text-slate">{item.body}</p>
          </article>
        ))
      }
    </div>
  </Section>

  <Section
    tone="surface"
    aria-labelledby="services-title"
    class="border-b border-hairline !py-12 lg:!py-16"
  >
    <div class="reveal grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
      <div>
        <p class="eyebrow">Services</p>
        <h2
          id="services-title"
          class="mt-5 text-[length:var(--text-title)] leading-[1.02] font-semibold tracking-[-0.045em] text-navy"
        >
          Six doors into one assurance system.
        </h2>
      </div>
      <p class="max-w-2xl text-lg text-slate lg:justify-self-end">
        Start with the line you need today. Keep a coherent operating model as your audit,
        governance, automation and training needs expand.
      </p>
    </div>

    <div class="mt-12 grid gap-3">
      {
        SERVICES.map((s, i) => (
          <a href={s.href} class="reveal service-slab group no-underline">
            <span class="service-slab-number">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h3>{s.name}</h3>
              <p>{s.summary}</p>
            </div>
            <span class="service-slab-arrow" aria-hidden="true">
              &rarr;
            </span>
          </a>
        ))
      }
    </div>
  </Section>

  <Section
    tone="paper"
    aria-labelledby="audience-title"
    class="border-b border-hairline !py-12 lg:!py-16"
  >
    <div class="reveal mx-auto max-w-3xl text-center">
      <p class="eyebrow is-centred">Who it is for</p>
      <h2
        id="audience-title"
        class="mt-5 text-[length:var(--text-title)] leading-[1.02] font-semibold tracking-[-0.045em] text-navy"
      >
        Built for organisations where assurance has consequences.
      </h2>
    </div>
    <div class="mt-12 grid gap-4 md:grid-cols-2 lg:grid-cols-5">
      {
        AUDIENCE.map((seg) => (
          <div class="reveal audience-tile">
            <p>{seg.name}</p>
            <span>{seg.note}</span>
          </div>
        ))
      }
    </div>
  </Section>

  {
    topGuides.length > 0 && (
      <Section
        tone="surface"
        aria-labelledby="guides-title"
        class="border-b border-hairline !py-12 lg:!py-16"
      >
        <div class="reveal flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="eyebrow">Insights</p>
            <h2
              id="guides-title"
              class="mt-5 text-[length:var(--text-title)] leading-[1.02] font-semibold tracking-[-0.045em] text-navy"
            >
              Learn the thinking behind the system
            </h2>
          </div>
          <a
            href="/insights"
            class="font-medium text-blue no-underline hover:text-blue-deep hover:underline"
          >
            All insights &rarr;
          </a>
        </div>
        <FeatureGrid cols={3} class="mt-12">
          {topGuides.map((g) => (
            <Card href={`/insights/${g.id}/`} class="reveal flex flex-col">
              {g.data.category && <p class="eyebrow text-xs">{g.data.category}</p>}
              <h3 class="mt-3 text-lg text-navy">{g.data.title}</h3>
              <p class="mt-2 grow text-slate">{g.data.description}</p>
              <span
                aria-hidden="true"
                class="mt-5 inline-flex items-center gap-1 text-sm font-medium text-blue"
              >
                Read guide <span>&rarr;</span>
              </span>
            </Card>
          ))}
        </FeatureGrid>
      </Section>
    )
  }

  <Section tone="paper" aria-labelledby="home-faq" class="!py-12 lg:!py-16">
    <div class="reveal max-w-2xl">
      <p class="eyebrow">Questions</p>
      <h2
        id="home-faq"
        class="mt-5 text-[length:var(--text-title)] leading-[1.02] font-semibold tracking-[-0.045em] text-navy"
      >
        Questions before you book
      </h2>
    </div>
    <Faq items={faqs} class="reveal mt-10 max-w-3xl" />
    <FaqPageSchema items={faqs} />
  </Section>

  <CtaSection
    eyebrow="Book a demo"
    title="Make your assurance function feel composed, current and board-ready"
    body="Book a demo and we will map Murikah to your audit universe, your regulator and your board."
    secondaryLabel="Contact us"
    secondaryHref="/contact"
  />
</BaseLayout>
