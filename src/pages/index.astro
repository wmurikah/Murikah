---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/primitives/Section.astro';
import Button from '@/components/primitives/Button.astro';
import Card from '@/components/primitives/Card.astro';
import FeatureGrid from '@/components/primitives/FeatureGrid.astro';
import Stat from '@/components/primitives/Stat.astro';
import CtaSection from '@/components/primitives/CtaSection.astro';
import { SERVICES, PRIMARY_CTA, FOUNDER } from '@/site.config';

// Audience groups — chunked into roles vs. organisation types (Miller's Law).
const audienceRoles = [
  'Heads of internal audit',
  'Audit committee & board chairs',
  'CFOs and CEOs',
  'Heads of risk & compliance',
];
const audienceOrgs = ['SACCOs', 'Banks', 'Microfinance & fintechs', 'Donor-funded NGOs'];
---

<BaseLayout
  title={undefined}
  description="Murikah helps African organisations run, prove, and continuously improve internal audit and AI and system governance — at a fraction of the cost and rigidity of the Big 4 and enterprise GRC software."
>
  {/* ----------------------------------------------------------------- Hero */}
  {
    /* Peak–End: the hero is the strongest opening moment. The H1 is the only
      place Fraunces (serif) is used, per the type rules. */
  }
  <Section tone="paper" class="relative overflow-hidden" aria-labelledby="hero-title">
    <div class="relative z-10 max-w-3xl">
      <p class="text-sm font-semibold tracking-widest text-gold uppercase">
        AI-native assurance &amp; governance
      </p>
      <h1
        id="hero-title"
        class="mt-4 font-serif text-[length:var(--text-display)] leading-[1.04] font-semibold tracking-[-0.025em] text-balance text-navy"
      >
        Assurance. Systems. Intelligence.
      </h1>
      <p class="mt-6 max-w-prose text-lg text-slate sm:text-xl">
        Run, prove, and continuously improve your internal audit and your AI and system governance —
        at a fraction of the cost and rigidity of the Big&nbsp;4 and enterprise GRC software. <span
          class="text-slate/80">[placeholder value statement]</span
        >
      </p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <Button href={PRIMARY_CTA.href} variant="primary" size="lg">{PRIMARY_CTA.label}</Button>
        <Button href="/assurance" variant="ghost" size="lg">Explore services</Button>
      </div>
    </div>

    {/* Decorative flourish — purely aesthetic, hidden from assistive tech. */}
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -top-24 -right-24 -z-0 hidden h-96 w-96 rounded-full bg-gold/10 blur-3xl lg:block"
    >
    </div>
  </Section>

  {/* ------------------------------------------------- Six lines of work */}
  <Section tone="surface" aria-labelledby="services-title" class="border-y border-hairline">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold tracking-widest text-gold uppercase">What we do</p>
      <h2 id="services-title" class="mt-3 text-3xl sm:text-4xl">Six lines of work, one standard</h2>
      <p class="mt-4 text-slate">
        From co-sourced assurance to the platform that runs it — each line stands alone or works
        together. <span class="text-slate/80">[placeholder]</span>
      </p>
    </div>

    <FeatureGrid cols={3} class="mt-10">
      {
        SERVICES.map((s) => (
          <Card href={s.href} class="group flex flex-col">
            <h3 class="text-xl text-navy">{s.fullName}</h3>
            <p class="mt-2 grow text-slate">{s.summary.replace(' [placeholder]', '')}</p>
            <span class="mt-4 inline-flex items-center gap-1 font-medium text-blue">
              Learn more
              <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">
                &rarr;
              </span>
            </span>
          </Card>
        ))
      }
    </FeatureGrid>
  </Section>

  {/* ----------------------------------------------------- Who it's for */}
  <Section tone="paper" aria-labelledby="audience-title">
    <h2 id="audience-title" class="text-3xl sm:text-4xl">Who it's for</h2>
    <p class="mt-4 max-w-prose text-slate">
      Built for regulated, mid-market organisations and the people accountable for assurance.
      <span class="text-slate/80">[placeholder]</span>
    </p>

    <div class="mt-10 grid gap-10 lg:grid-cols-2">
      <div>
        <h3 class="text-sm font-semibold tracking-widest text-slate uppercase">People</h3>
        <ul class="mt-4 grid gap-3 sm:grid-cols-2">
          {
            audienceRoles.map((role) => (
              <li class="rounded-card bg-surface px-4 py-3.5 font-medium text-navy ring-1 ring-hairline/70">
                {role}
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold tracking-widest text-slate uppercase">Organisations</h3>
        <ul class="mt-4 grid gap-3 sm:grid-cols-2">
          {
            audienceOrgs.map((org) => (
              <li class="rounded-card bg-surface px-4 py-3.5 font-medium text-navy ring-1 ring-hairline/70">
                {org}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </Section>

  {/* ------------------------------------------------------ Trust strip */}
  {/* E-E-A-T: real, verifiable founder credentials — no invented metrics. */}
  <Section tone="shade" aria-labelledby="trust-title">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold tracking-widest text-gold uppercase">Why Murikah</p>
      <h2 id="trust-title" class="mt-3 text-3xl sm:text-4xl">
        Built and led by a certified practitioner
      </h2>
      <p class="mt-4 text-slate">
        Founded, built and led by {FOUNDER.name} — combining hands-on audit, security and AI-governance
        credentials with the platform engineering behind Audit&nbsp;OS.
        <span class="text-slate/80">[placeholder bio summary]</span>
      </p>
    </div>

    <div
      class="mt-10 grid gap-8 rounded-card bg-surface p-8 ring-1 ring-hairline/70 sm:grid-cols-3"
    >
      <Stat value="ISO 42001" label="AI management systems" hint="Lead Auditor" />
      <Stat value="ISO 27001" label="Information security" hint="Lead Auditor" />
      <Stat value="CISA" label="Information systems audit" hint="Certified" />
    </div>

    <ul class="mt-6 flex flex-wrap gap-2" aria-label="Founder credentials">
      {
        FOUNDER.credentials.map((c) => (
          <li class="rounded-full bg-surface px-3 py-1 text-sm text-ink ring-1 ring-hairline">
            {c}
          </li>
        ))
      }
    </ul>

    <p class="mt-6">
      <a href="/about" class="font-medium text-blue hover:text-blue-deep">
        Read about Murikah &amp; the founder &rarr;
      </a>
    </p>
  </Section>

  {/* ------------------------------------------------------ Closing CTA */}
  <CtaSection
    eyebrow="Get started"
    title="Bring rigour, proof and intelligence to your assurance"
    body="Book a demo and we'll show how Murikah maps to your audit universe and governance obligations. [placeholder]"
    secondaryLabel="Contact us"
    secondaryHref="/contact"
  />
</BaseLayout>
