---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/primitives/Section.astro';
import Prose from '@/components/primitives/Prose.astro';
import Breadcrumb from '@/components/primitives/Breadcrumb.astro';
import { SITE } from '@/site.config';

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Privacy', href: '/privacy' },
];
---

<BaseLayout
  title="Privacy policy"
  description="How Murikah collects, uses and protects personal data."
  noindex={true}
>
  <Section tone="surface" aria-labelledby="page-title">
    <Breadcrumb items={crumbs} class="mb-6" />
    <h1 id="page-title" class="text-4xl sm:text-5xl">Privacy policy</h1>
    <p class="mt-3 text-slate">Last updated: [placeholder date]</p>

    <div
      class="mt-6 rounded-card border border-hairline bg-paper p-4 text-sm text-slate"
      role="note"
    >
      <strong class="text-navy">Placeholder:</strong> this is a structural stub, not final legal text.
      A data-protection brand must ship a real, reviewed policy before launch.
    </div>

    <Prose class="mt-10">
      <h2>Who we are</h2>
      <p>
        {SITE.legalName} (“Murikah”, “we”, “us”) provides assurance, governance and related services.
        This policy explains how we handle personal data. [placeholder]
      </p>

      <h2>What we collect</h2>
      <p>
        Information you provide through our contact and subscription forms (such as your name,
        organisation, role, email and message), and basic technical data needed to operate the site
        securely. [placeholder]
      </p>

      <h2>How we use it</h2>
      <ul>
        <li>To respond to enquiries and provide requested services. [placeholder]</li>
        <li>To send updates you have subscribed to. [placeholder]</li>
        <li>To secure, maintain and improve the website. [placeholder]</li>
      </ul>

      <h2>Legal basis & retention</h2>
      <p>
        We process data on the bases permitted by applicable law and retain it only as long as
        necessary for the purposes above. [placeholder]
      </p>

      <h2>Your rights</h2>
      <p>
        You may request access, correction or deletion of your personal data, and you may object to
        certain processing, subject to applicable law. [placeholder]
      </p>

      <h2>Contact</h2>
      <p>
        For any privacy request, contact <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
        [placeholder]
      </p>
    </Prose>
  </Section>
</BaseLayout>
